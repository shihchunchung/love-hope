{% block scripts %}
<script>
// ============ HERO BANNER carousel (center-focus + side-peek, infinite) ============
  (function(){
    const stage  = document.getElementById('bannerStage');
    const track  = document.getElementById('bannerTrack');
    const real   = Array.from(track.querySelectorAll('.banner-slide'));
    const dots   = document.querySelectorAll('.banner-dots button');
    const prev   = stage.querySelector('.banner-arrow.prev');
    const next   = stage.querySelector('.banner-arrow.next');
    const GAP    = 16;
    const N      = real.length;

    const makeClone = s => { const c = s.cloneNode(true); c.classList.remove('on'); c.dataset.clone = '1'; return c; };
    real.forEach(s => track.appendChild(makeClone(s)));
    [...real].reverse().forEach(s => track.insertBefore(makeClone(s), track.firstChild));
    const slides = track.querySelectorAll('.banner-slide');

    let pos = N;
    let timer, animating = false;

    function translate(animate){
      const stageW = stage.clientWidth;
      const slideW = slides[0].getBoundingClientRect().width;
      const offset = (stageW / 2) - (slideW / 2) - pos * (slideW + GAP);
      track.style.transition = animate ? '' : 'none';
      track.style.transform  = 'translateX(' + offset + 'px)';
      if (!animate){ void track.offsetWidth; track.style.transition = ''; }
    }
    function paintActive(){
      const realIdx = ((pos - N) % N + N) % N;
      slides.forEach((s, i) => s.classList.toggle('on', i === pos));
      dots.forEach((d, i)   => d.classList.toggle('on', i === realIdx));
    }
    function step(delta){
      if (animating) return;
      animating = true; pos += delta; translate(true); paintActive();
    }
    track.addEventListener('transitionend', e => {
      if (e.propertyName !== 'transform') return;
      animating = false;
      if (pos < N)        { pos += N; translate(false); paintActive(); }
      else if (pos >= 2*N){ pos -= N; translate(false); paintActive(); }
    });
    function autoplay(){ clearInterval(timer); timer = setInterval(() => step(1), 6000); }
    function jumpTo(realIdx){
      if (animating) return;
      animating = true; pos = N + realIdx; translate(true); paintActive();
    }
    dots.forEach(d => d.addEventListener('click', () => { jumpTo(parseInt(d.dataset.idx, 10)); autoplay(); }));
    prev.addEventListener('click', () => { step(-1); autoplay(); });
    next.addEventListener('click', () => { step(1);  autoplay(); });
    window.addEventListener('resize', () => translate(false));
    requestAnimationFrame(() => { translate(false); paintActive(); autoplay(); });
  })();

  // ============ TRENDING carousel (native scroll-snap + arrow + autoplay) ============
  (function(){
    const root = document.getElementById('trendFrame');
    if (!root) return;
    const track = root.querySelector('.trend-track');
    const card  = track.querySelector('.trend-card');
    if (!card) return;

    const stepSize = () => card.getBoundingClientRect().width + 24;

    root.querySelector('.trend-arrow.prev').addEventListener('click',
      () => track.scrollBy({left: -stepSize(), behavior:'smooth'}));
    root.querySelector('.trend-arrow.next').addEventListener('click',
      () => track.scrollBy({left:  stepSize(), behavior:'smooth'}));

    let paused = false;
    track.addEventListener('mouseenter', () => paused = true);
    track.addEventListener('mouseleave', () => paused = false);
    track.addEventListener('touchstart', () => paused = true, {passive:true});

    setInterval(() => {
      if (paused) return;
      const max = track.scrollWidth - track.clientWidth - 4;
      if (track.scrollLeft >= max) track.scrollTo({left: 0, behavior:'smooth'});
      else track.scrollBy({left: stepSize(), behavior:'smooth'});
    }, 5000);
  })();
</script>
{% endblock %}
