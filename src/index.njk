---
permalink: index.html
title: "薛伯輝基金會 Love Hope Foundation"
active: home
---
{% extends "base.njk" %}

{% block styles %}
<style>
  /* ============ HERO BANNER (La Vie banner-slider 風格) ============ */
  .banner-slider{padding:var(--sp-6) 0 0;background:#fff;position:relative}
  .banner-stage{position:relative;width:100%;overflow:hidden}
  .banner-track{display:flex;gap:var(--sp-4);will-change:transform;transition:transform .5s cubic-bezier(.4,0,.2,1)}
  .banner-slide{flex:0 0 1050px;aspect-ratio:1050/578;position:relative;background:#0a0a0a;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;padding:0;color:#fff;cursor:pointer;text-decoration:none}
  .banner-slide::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(0,0,0,.65) 100%);pointer-events:none;z-index:1}
  .banner-slide .h-title{position:relative;z-index:2;padding:var(--sp-7) var(--sp-7);font-size:var(--t-display);line-height:1.35;font-weight:600;color:#fff;letter-spacing:1px;max-width:760px;opacity:0;transform:translateY(12px);transition:opacity .45s ease .1s,transform .45s ease .1s;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin:0}
  .banner-slide.on .h-title{opacity:1;transform:translateY(0)}
  .banner-slide-1{background:linear-gradient(135deg,#5a0808 0%,#1a0202 100%)}
  .banner-slide-2{background:linear-gradient(135deg,#2a2a2a 0%,#0a0a0a 100%)}
  .banner-slide-3{background:linear-gradient(135deg,#3a1818 0%,#1a0808 100%)}

  .banner-arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:5;width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,.85);color:var(--ink);display:flex;align-items:center;justify-content:center;font-size:20px;font-family:"IBM Plex Serif",sans-serif;line-height:1;box-shadow:0 2px 10px rgba(0,0,0,.12);cursor:pointer;opacity:.5;transition:opacity .2s,background .2s,transform .2s;border:0}
  .banner-arrow:hover{opacity:1;background:#fff;transform:translateY(-50%) scale(1.05)}
  .banner-arrow.prev{left:calc((100% - 1050px)/4 + 7rem)}
  .banner-arrow.next{right:calc((100% - 1050px)/4 + 7rem)}
  .banner-dots{display:flex;justify-content:center;gap:var(--sp-3);margin-top:var(--sp-7);height:36px;align-items:center}
  .banner-dots button{width:8px;height:8px;border-radius:50%;background:#d4d4d8;transition:background .25s,transform .25s;padding:0;border:0}
  .banner-dots button:hover{background:#9a9a9a}
  .banner-dots button.on{background:#18181b;transform:scale(1.15)}

  /* ============ SECTION + 中英雙層標頭 (La Vie 主節奏) ============ */
  section.section{padding:var(--sp-9) 0}
  section.section.is-paper{background:#F8F4EE}
  .banner-slider + section.section{padding-top:var(--sp-7)}
  .section-head{display:flex;justify-content:space-between;align-items:flex-end;border-bottom:1px solid var(--ink);padding-bottom:var(--sp-6);margin-bottom:var(--sp-7)}
  .section-head .titles{display:flex;flex-direction:column;gap:var(--sp-3)}
  .section-head h2.section-title{font-size:var(--t-section);font-weight:700;color:var(--ink);letter-spacing:1.5px;line-height:1.25}
  .section-head .subtitle{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:3.5px;color:var(--brand);font-weight:600;text-transform:uppercase;display:flex;align-items:center;gap:var(--sp-4)}
  .section-head .subtitle::before{content:"";width:24px;height:1px;background:var(--brand)}
  .s-more{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--ink);font-weight:600;display:inline-flex;align-items:center;gap:var(--sp-2);border-bottom:1px solid var(--ink);padding-bottom:var(--sp-1);transition:.2s;align-self:flex-end;padding-bottom:var(--sp-2)}
  .s-more:hover{color:var(--brand);border-color:var(--brand)}

  /* ============ UTILITIES (La Vie has-* helpers) ============ */
  .has-hover-scale{overflow:hidden}
  .has-hover-scale .img-fill{transition:transform .55s cubic-bezier(.25,.46,.45,.94)}
  a:hover .has-hover-scale .img-fill{transform:scale(1.05)}
  .has-hover-color-change{transition:color .2s}
  a:hover .has-hover-color-change{color:var(--brand)}
  .has-loading-spin{position:relative}
  .has-loading-spin::before{content:"";position:absolute;top:50%;left:50%;width:32px;height:32px;margin:-var(--sp-4) 0 0 -var(--sp-4);border-radius:50%;border:2px solid transparent;border-top-color:rgba(255,255,255,.6);border-right-color:rgba(255,255,255,.6);animation:spin 1s linear infinite;opacity:.6;z-index:0}
  @keyframes spin{to{transform:rotate(360deg)}}
  .c-tag{display:inline-block;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--brand);font-weight:700}

  /* La Vie 灰色偏移底塊 */
  .has-before-background{position:relative;isolation:isolate}
  .has-before-background::before{content:"";position:absolute;background:var(--line-soft);z-index:-1}
  .has-before-background.is-offset-br::before{inset:32px -32px -32px 32px}
  .has-before-background.is-offset-bl::before{inset:32px 32px -32px -32px}

  /* ============ LATEST: 3 欄等寬 9:5 (La Vie article-card) ============ */
  .article-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--sp-7) var(--sp-6);margin-bottom:var(--sp-7)}
  .article-card{display:block;cursor:pointer}
  .article-card-image{aspect-ratio:9/5;overflow:hidden;background:linear-gradient(135deg,#3a1818,#1a0202);position:relative;margin-bottom:var(--sp-4)}
  .article-card-image .img-fill{position:absolute;inset:0;background:inherit;transition:transform .55s cubic-bezier(.25,.46,.45,.94)}
  .article-card:hover .article-card-image .img-fill{transform:scale(1.05)}
  /* LATEST 系列漸層 (scoped) */
  .article-grid.is-latest .article-card:nth-child(2) .article-card-image{background:linear-gradient(135deg,#a89070,#604530)}
  .article-grid.is-latest .article-card:nth-child(3) .article-card-image{background:linear-gradient(135deg,#888,#3a3a3a)}
  .article-grid.is-latest .article-card:nth-child(4) .article-card-image{background:linear-gradient(135deg,#c4a880,#704830)}
  .article-grid.is-latest .article-card:nth-child(5) .article-card-image{background:linear-gradient(135deg,#5a3a2a,#1a1010)}
  .article-grid.is-latest .article-card:nth-child(6) .article-card-image{background:linear-gradient(135deg,#8C0A0A,#3a1818)}
  /* ABOUT 系列漸層 */
  .article-card.is-about .article-card-image{background:linear-gradient(160deg,#5a0808,#1a0202)}
  .article-card.is-portrait-1 .article-card-image{background:linear-gradient(160deg,#3a3a3a,#0a0a0a)}
  .article-card.is-portrait-2 .article-card-image{background:linear-gradient(160deg,#5a3a28,#1a0808)}
  /* SUPPORT 系列漸層 (scoped) */
  .article-grid.is-support .article-card:nth-child(1) .article-card-image{background:linear-gradient(135deg,#a89070,#604530)}
  .article-grid.is-support .article-card:nth-child(2) .article-card-image{background:linear-gradient(135deg,#c8a880,#704830)}
  .article-grid.is-support .article-card:nth-child(3) .article-card-image{background:linear-gradient(135deg,#b8a890,#5a4830)}

  .article-card-image .since-mark{position:absolute;bottom:18px;left:18px;color:#fff;z-index:2}
  .article-card-image .since-mark .lbl{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:3px;text-transform:uppercase;display:block;opacity:.7;margin-bottom:var(--sp-1);font-weight:600}
  .article-card-image .since-mark .yr{font-family:"IBM Plex Serif",sans-serif;font-size:42px;font-weight:800;letter-spacing:-1px;line-height:1}
  .article-card .meta{display:flex;gap:var(--sp-3);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:var(--sp-3)}
  .article-card .meta .cat{color:var(--brand);font-weight:700}
  .article-card .title{font-size:var(--t-title);line-height:1.5;font-weight:700;letter-spacing:0;color:var(--ink);margin-bottom:var(--sp-4);display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;transition:color .2s}
  .article-card:hover .title{color:var(--brand)}
  .article-card .description{font-size:var(--t-body);line-height:1.85;color:var(--body);margin:0 0 var(--sp-4);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .article-card .byline{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:1.5px;color:var(--muted)}
  .article-card .article-action{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--ink);font-weight:600;border-bottom:1px solid var(--ink);padding-bottom:3px;display:inline-block;transition:.2s}
  .article-card:hover .article-action{color:var(--brand);border-color:var(--brand)}

  .view-more-wrap{display:flex;justify-content:center}
  .view-more-btn{display:inline-flex;align-items:center;gap:var(--sp-3);justify-content:center;padding:var(--sp-3) var(--sp-6);border:1px solid var(--ink);color:var(--ink);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:3px;text-transform:uppercase;font-weight:600;transition:all .2s;background:#fff}
  .view-more-btn::after{content:"→"}
  .view-more-btn:hover{background:var(--ink);color:#fff;border-color:var(--ink)}

  /* ============ TRENDING: 輪播 + 大數字角標 (La Vie 標誌做法) ============ */
  .trend-frame{position:relative;margin:0 -var(--sp-2)}
  .trend-track{display:flex;gap:var(--sp-5);overflow-x:auto;scroll-snap-type:x mandatory;scroll-behavior:smooth;scrollbar-width:none;-ms-overflow-style:none;padding:var(--sp-2) var(--sp-2) var(--sp-4);cursor:grab}
  .trend-track:active{cursor:grabbing}
  .trend-track::-webkit-scrollbar{display:none}
  .trend-card{flex:0 0 calc((100% - 88px)/4);scroll-snap-align:start;cursor:pointer;display:block}
  .trend-img{aspect-ratio:4/5;position:relative;overflow:hidden;background:linear-gradient(135deg,#3a1818,#0a0202)}
  .trend-img .img-fill{position:absolute;inset:0;background:inherit;transition:transform .55s cubic-bezier(.25,.46,.45,.94)}
  .trend-card:hover .trend-img .img-fill{transform:scale(1.05)}
  .trend-img::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(0,0,0,.55) 100%);pointer-events:none;z-index:1}
  .trend-img .rank{position:absolute;left:14px;top:14px;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);font-weight:600;line-height:1;color:#fff;letter-spacing:3px;text-transform:uppercase;z-index:2;display:inline-flex;align-items:baseline;gap:var(--sp-1)}
  .trend-img .rank::before{content:"No.";opacity:.7;font-weight:400;font-style:italic}
  .trend-card:nth-child(2) .trend-img{background:linear-gradient(135deg,#604530,#2a1808)}
  .trend-card:nth-child(3) .trend-img{background:linear-gradient(135deg,#3a3a3a,#0a0a0a)}
  .trend-card:nth-child(4) .trend-img{background:linear-gradient(135deg,#704830,#2a1a0a)}
  .trend-card:nth-child(5) .trend-img{background:linear-gradient(135deg,#5a3a2a,#1a1010)}
  .trend-card:nth-child(6) .trend-img{background:linear-gradient(135deg,#3a2828,#1a0808)}
  .trend-card:nth-child(7) .trend-img{background:linear-gradient(135deg,#a89070,#604530)}
  .trend-card:nth-child(8) .trend-img{background:linear-gradient(135deg,#c8a880,#5a4830)}
  .trend-body{padding:var(--sp-5) var(--sp-1) 0}
  .trend-body .meta{display:flex;gap:var(--sp-3);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:var(--sp-2)}
  .trend-body .cat{color:var(--brand);font-weight:700}
  .trend-body h4{font-size:var(--t-title-s);line-height:1.75;font-weight:600;color:var(--ink);letter-spacing:.5px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;transition:color .2s}
  .trend-card:hover h4{color:var(--brand)}
  .trend-arrow{position:absolute;top:34%;z-index:5;width:42px;height:42px;border-radius:50%;background:#fff;border:1px solid var(--line);color:var(--ink);display:flex;align-items:center;justify-content:center;font-size:24px;cursor:pointer;transition:all .2s;box-shadow:0 4px 14px rgba(0,0,0,.08);font-family:"IBM Plex Serif",sans-serif;line-height:1}
  .trend-arrow:hover{background:var(--brand);border-color:var(--brand);color:#fff}
  .trend-arrow.prev{left:-20px}
  .trend-arrow.next{right:-20px}

  /* ============ SPECIAL ISSUE: 5 公益行動 ============ */
  .actions-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}
  .act{background:#fff;cursor:pointer;transition:background .25s;display:flex;flex-direction:column}
  .act:hover{background:var(--brand-tint)}
  .act .img{aspect-ratio:4/5;position:relative;overflow:hidden;background:linear-gradient(180deg,#5a0808,#1a0202)}
  .act .img .img-fill{position:absolute;inset:0;background:inherit;transition:transform .55s cubic-bezier(.25,.46,.45,.94)}
  .act:hover .img .img-fill{transform:scale(1.05)}
  .act .img .num{position:absolute;top:18px;left:18px;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;color:rgba(255,255,255,.85);font-weight:600;z-index:2}
  .act .img .lbl{position:absolute;bottom:14px;right:14px;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.55);z-index:2}
  .act .body{padding:var(--sp-6);flex:1;display:flex;flex-direction:column}
  .act .cat{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--brand);font-weight:700;margin-bottom:var(--sp-3)}
  .act h4{font-size:var(--t-title);letter-spacing:1px;line-height:1.5;margin-bottom:var(--sp-4);font-weight:700;color:var(--ink)}
  .act p{font-size:var(--t-body-s);color:var(--muted);line-height:1.85;flex:1}
  .act .arr{margin-top:var(--sp-4);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2px;color:var(--ink);font-weight:600;text-transform:uppercase}
  .act .arr::after{content:" →"}
  .act:nth-child(2) .img{background:linear-gradient(180deg,#3a3a3a,#0a0a0a)}
  .act:nth-child(3) .img{background:linear-gradient(180deg,#704830,#2a1808)}
  .act:nth-child(4) .img{background:linear-gradient(180deg,#5a3a2a,#2a1a0a)}
  .act:nth-child(5) .img{background:linear-gradient(180deg,#3a1818,#1a0808)}
  .act:nth-child(6) .img{background:linear-gradient(180deg,#4a4a4a,#1a1a1a)}

  /* ============ SPOTLIGHT: 真愛多多 (feature-card 收縮版) ============ */
  .spot-band{display:grid;grid-template-columns:1.4fr 1fr;min-height:440px;background:#fff}
  .spot-img{background:linear-gradient(135deg,#5a0808 0%,#1a0202 100%);position:relative;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.4);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:3px;text-transform:uppercase;overflow:hidden}
  .spot-img .img-fill{position:absolute;inset:0;background:inherit}
  .spot-img::before{content:"▶";position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,.1);backdrop-filter:blur(6px);border:1px solid rgba(255,255,255,.4);color:#fff;font-size:20px;display:flex;align-items:center;justify-content:center;padding-left:var(--sp-1);z-index:2}
  .spot-img .meta{position:absolute;top:24px;left:24px;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:3px;text-transform:uppercase;color:#fff;display:flex;gap:var(--sp-3);align-items:center;z-index:2}
  .spot-img .meta .cat{background:var(--brand);padding:var(--sp-1) var(--sp-3);font-weight:700}
  .spot-img .lnk{position:absolute;bottom:24px;left:24px;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.6);z-index:2}
  .spot-text{padding:var(--sp-7) var(--sp-7);display:flex;flex-direction:column;justify-content:center}
  .spot-text .label{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:3px;text-transform:uppercase;color:var(--brand);font-weight:700;margin-bottom:var(--sp-4);display:flex;align-items:center;gap:var(--sp-3)}
  .spot-text .label::before{content:"";width:24px;height:1px;background:var(--brand)}
  .spot-text h2{font-size:var(--t-section);line-height:1.35;font-weight:700;letter-spacing:1px;margin-bottom:var(--sp-5);color:var(--ink)}
  .spot-text .quote{font-size:var(--t-title-s);line-height:1.85;color:var(--ink);font-weight:500;border-left:2px solid var(--brand);padding-left:var(--sp-4);margin-bottom:var(--sp-5);letter-spacing:0}
  .spot-text .ctas{display:flex;gap:var(--sp-4);flex-wrap:wrap}
  .spot-text .btn-r{display:inline-flex;align-items:center;gap:var(--sp-3);padding:var(--sp-3) var(--sp-5);background:var(--brand);color:#fff;font-size:var(--t-meta);letter-spacing:2.5px;font-weight:500;transition:background .2s}
  .spot-text .btn-r::after{content:"→"}
  .spot-text .btn-r:hover{background:var(--brand-dark)}
  .spot-text .btn-l{display:inline-flex;align-items:center;gap:var(--sp-3);padding:var(--sp-3) var(--sp-5);border:1px solid var(--ink);color:var(--ink);font-size:var(--t-meta);letter-spacing:2.5px;font-weight:500;transition:all .2s}
  .spot-text .btn-l:hover{background:var(--ink);color:#fff}

  /* ============ COOKIE ============ */

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1100px){
    .banner-slide{flex-basis:min(720px, calc(100vw - 80px))}
    .banner-arrow.prev{left:16px}
    .banner-arrow.next{right:16px}
    .article-grid{grid-template-columns:repeat(2,1fr);gap:var(--sp-7) var(--sp-5);margin-bottom:var(--sp-7)}
    .actions-grid{grid-template-columns:repeat(2,1fr)}
    .trend-card{flex:0 0 calc((100% - 32px)/2)}
    .trend-arrow{display:none}
    .spot-band{grid-template-columns:1fr}
    .spot-text{padding:var(--sp-6) var(--sp-6)}
    .donate-band{padding:var(--sp-7) 0}
    .donate-card{grid-template-columns:1fr;gap:var(--sp-7);padding:var(--sp-7);border-radius:4px}
    .donate-text{padding:0}
    .donate-stats{border-left:none;border-top:1px solid rgba(255,255,255,.2);padding-left:0;padding-top:var(--sp-6)}
    .has-before-background.is-offset-br::before{inset:20px -16px -20px 20px}
  }
  @media (max-width: 720px){
    .app-header .row,.app-nav .row,.banner-slider,section.section,.app-footer{padding-left:var(--sp-4);padding-right:var(--sp-4)}
    section.section{padding:var(--sp-7) var(--sp-4)}

    .banner-slider{padding:0}
    .banner-slide{flex-basis:100vw;padding:0}
    .banner-arrow{display:none}
    .section-head{flex-direction:column;align-items:flex-start;gap:var(--sp-4)}
    .article-grid{grid-template-columns:1fr;gap:var(--sp-6)}
    .article-card .title{font-size:var(--t-body-l)}
    .actions-grid{grid-template-columns:1fr}
    .trend-card{flex:0 0 80%}
    .donate-band{padding:var(--sp-7) var(--sp-4)}
    .donate-card{padding:var(--sp-6) var(--sp-5);gap:var(--sp-6)}
    .donate-stats{padding-top:var(--sp-5)}
  }
</style>
{% endblock %}

{% block content %}
<!-- ===== HERO BANNER ===== -->
<section class="banner-slider">
  <div class="banner-stage" id="bannerStage">
    <button class="banner-arrow prev" aria-label="previous">‹</button>
    <button class="banner-arrow next" aria-label="next">›</button>
    <div class="banner-track" id="bannerTrack">
      <a class="banner-slide banner-slide-1 on" href="about.html">
        <h2 class="h-title">一步一步向前行，延續愛與希望的基金會</h2>
      </a>
      <a class="banner-slide banner-slide-2" href="people.html">
        <h2 class="h-title">紳士企業家薛伯輝，留下愛與希望的慈善身影</h2>
      </a>
      <a class="banner-slide banner-slide-3" href="true-love.html">
        <h2 class="h-title">完成甘惠忠神父的心願，伯利恆早療暨融合教育中心</h2>
      </a>
    </div>
  </div>
  <div class="banner-dots">
    <button class="on" data-idx="0" aria-label="slide 1"></button>
    <button data-idx="1" aria-label="slide 2"></button>
    <button data-idx="2" aria-label="slide 3"></button>
  </div>

</section>

