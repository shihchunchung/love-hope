{% block scripts %}
<script>
// ============ SUB-NAV 切換 ============
  (function(){
    // 5 個分類資料：標題 / 副標 / 是否為偏鄉教育花園（有內容）
    const CATEGORIES = {
      'care-garden': {
        title:'特別青年教養花園',
        lead:'為特別青年打造日常生活的庇護與成長空間，以照顧、陪伴與實作，孕育安穩的可能。',
        ready:false
      },
      aesthetic: {
        title:'陪伴力量大',
        lead:'以生活美學與文化底蘊，打造共學、共享、共榮的特別教育環境。',
        ready:true
      },
      music: {
        title:'奧兒福音樂會',
        lead:'讓音樂成為共融的語言，邀請孩子、家庭與社會共同聽見彼此的力量。',
        ready:false
      },
      elder: {
        title:'老人服務',
        lead:'關懷長者生活、陪伴與安全需求，讓照顧不只停在服務，也保有美感與尊嚴。',
        ready:false
      },
      other: {
        title:'其他',
        lead:'彙整不在主要分類中的其他支持與合作案例。',
        ready:false
      }
    };

    const subItems   = document.querySelectorAll('.sub-nav .item');
    const drawerSubs = document.querySelectorAll('.drawer-group .sub-item');
    const heroTitle  = document.getElementById('heroTitle');
    const heroLead   = document.getElementById('heroLead');
    const aesticList = document.getElementById('aestheticList');
    const emptyState = document.getElementById('emptyState');
    const emptyTitle = document.getElementById('emptyTitle');

    function setActive(cat){
      const c = CATEGORIES[cat];
      if (!c) return;

      // 切換 sub-nav 視覺
      subItems.forEach(it => it.classList.toggle('on', it.dataset.cat === cat));
      drawerSubs.forEach(it => it.classList.toggle('on', it.dataset.cat === cat));

      // 切 hero 文案（hero 標題只顯示分類名，狀態交給下方 empty-state）
      heroTitle.textContent = c.title;
      heroLead.textContent  = c.lead;

      // 切內容區
      if (c.ready){
        aesticList.hidden = false;
        emptyState.hidden = true;
      } else {
        aesticList.hidden = true;
        emptyState.hidden = false;
        emptyTitle.textContent = c.title + ' · 資料準備中';
      }
    }

    // 讀 URL hash 設定起始分類（從 detail page 的 sub-nav 連回時使用）
    const initHash = location.hash.replace('#', '');
    if (initHash && CATEGORIES[initHash]) {
      setActive(initHash);
    }

    subItems.forEach(it => {
      it.addEventListener('click', e => {
        e.preventDefault();              // 攔住 <a> 的真實導覽，做 in-place 切換
        setActive(it.dataset.cat);
        history.replaceState(null, '', '#' + it.dataset.cat); // 同步 URL hash
      });
    });
    drawerSubs.forEach(it => {
      it.addEventListener('click', () => {
        setActive(it.dataset.cat);
        // 子項點完關 drawer
        const d = document.getElementById('drawer');
        const b = document.getElementById('drawerBackdrop');
        if (d && b){
          d.classList.remove('on');
          b.classList.remove('on');
          d.setAttribute('aria-hidden','true');
          document.body.style.overflow = '';
        }
      });
    });
  })();

  // ============ DRAWER 二級展開 ============
  (function(){
    const head = document.getElementById('drawerActionsToggle');
    const grp  = document.getElementById('drawerActions');
    if (!head || !grp) return;
    head.addEventListener('click', () => grp.classList.toggle('on'));
  })();
</script>
{% endblock %}
