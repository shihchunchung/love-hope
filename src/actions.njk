{% extends "base.njk" %}

{% block styles %}
<style>
  /* ============ SUB-NAV (A · 鏡像主 nav) ============
     - 字級 12px / 字距 1.5px（明確比主 nav 14/2 小一級）
     - 上下 padding 13/19，無自身底邊（主 nav 品牌色底邊即為上邊）
     - sticky top 140 = header 86 + 主 nav 54
     - active：品牌色字 + 1px 細短橫（緊貼文字下方）
     - todo：#BBB 淺灰字 */
  .sub-nav{
    background:#fff;
    position:sticky;
    top:140px;
    z-index:48;
    display:flex;
    justify-content:center;
    align-items:stretch;
    padding:var(--sp-3) var(--sp-6) 19px;
  }
  .sub-nav .item{
    padding:0 var(--sp-5);
    font-size:var(--t-meta);
    letter-spacing:1.5px;
    color:#666;
    font-weight:500;
    position:relative;
    line-height:1.75;
    cursor:pointer;
    transition:color .18s;
    background:none;
    border:0;
    font-family:inherit;
  }
  .sub-nav .item:hover{color:var(--brand)}
  .sub-nav .item.todo{color:#BBB}
  .sub-nav .item.todo:hover{color:#999}
  .sub-nav .item.on{color:var(--brand);font-weight:700}
  /* active 短橫：複用 .subtitle::before 24×1px 記憶點，置中 */
  .sub-nav .item.on::after{
    content:"";
    position:absolute;
    left:50%;
    transform:translateX(-50%);
    bottom:-6px;
    width:24px;
    height:2px;
    background:var(--brand);
  }

  /* ============ PAGE HERO ============ */
  .page-hero{padding:var(--sp-9) 0 var(--sp-7);background:#fff;border-bottom:1px solid var(--ink)}
  .page-hero .wrap{max-width:1320px;margin:0 auto;padding:0 var(--sp-7)}
  .page-hero h1{font-size:var(--t-display-l);letter-spacing:1.5px;font-weight:700;color:var(--ink);line-height:1.25;margin-bottom:var(--sp-4)}
  .page-hero .lead{font-size:var(--t-title-s);color:var(--body);font-weight:500;line-height:1.85;max-width:640px;letter-spacing:0}

  /* ============ UNITS LIST (editorial 列表：圖左文右、大圖) ============ */
  .units-section{padding:var(--sp-8) 0 var(--sp-10);background:#fff}
  [hidden]{display:none !important}
  .unit-list{display:flex;flex-direction:column}
  .unit-row{
    display:grid;grid-template-columns:720px 1fr;gap:var(--sp-8);
    padding:var(--sp-4);margin:0 -var(--sp-4) var(--sp-1);
    align-items:center;transition:background .2s;
  }
  .unit-row:last-child{margin-bottom:0}
  .unit-row:hover{background:var(--line-soft)}

  .unit-image{
    aspect-ratio:16/9;overflow:hidden;position:relative;
    background:linear-gradient(135deg,#2a2a2a,#0f0f0f);
  }
  .unit-image .img-fill{
    position:absolute;inset:0;background:inherit;
    transition:transform .55s cubic-bezier(.25,.46,.45,.94);
  }
  .unit-row:hover .unit-image .img-fill{transform:scale(1.05)}
  .unit-image::after{
    content:"";position:absolute;inset:0;
    background:linear-gradient(180deg,transparent 55%,rgba(0,0,0,.45) 100%);
    pointer-events:none;z-index:1;
  }
  .unit-body{min-width:0;padding-right:var(--sp-5)}
  /* 地點：上提到標題之前當 eyebrow */
  .unit-body .meta{
    display:flex;gap:var(--sp-3);font-family:"IBM Plex Serif",sans-serif;
    font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;
    color:var(--muted);margin-bottom:var(--sp-4);
  }
  .unit-body .meta .cat{color:var(--brand);font-weight:700}

  .unit-body .title{font-size:var(--t-title-l);line-height:1.5;font-weight:700;letter-spacing:1px;
    color:var(--ink);margin-bottom:var(--sp-4);transition:color .2s;
  }
  .unit-row:hover .title{color:var(--brand)}

  /* 引文：拿掉 italic、2px 品牌色左 border + 16px 內縮，完整顯示不 clamp */
  .unit-body .quote{
    font-size:var(--t-title-s);line-height:1.85;color:var(--body);
    margin:0 0 var(--sp-5);border-left:2px solid var(--brand);padding-left:var(--sp-4);
    letter-spacing:0;
  }

  /* 導讀 excerpt：60–80 字摘要，CMS 欄位 */
  .unit-body .excerpt{
    font-size:var(--t-body-s);line-height:1.85;color:var(--body);
    margin:0 0 var(--sp-5);letter-spacing:0;
  }

  /* keywords：CMS keywords[] — # tag 樣式，襯線 # + sans 中文 */
  ul.keywords{
    list-style:none;padding:0;margin:0 0 var(--sp-4);
    display:flex;flex-wrap:wrap;gap:var(--sp-4);
    font-family:-apple-system,BlinkMacSystemFont,"PingFang TC","Noto Sans TC","Microsoft JhengHei",sans-serif;
    font-size:var(--t-meta);color:var(--muted);letter-spacing:0;
    transition:color .2s;
  }
  .keywords li{display:inline-flex;align-items:baseline;gap:var(--sp-1)}
  .keywords li::before{
    content:"#";font-family:"IBM Plex Serif",sans-serif;
    color:#C9B9B9;font-weight:500;transition:color .2s;
  }
  .unit-row:hover .keywords{color:var(--brand)}
  .unit-row:hover .keywords li::before{color:var(--brand)}

  /* CTA：抄 index .article-action */
  .unit-body .article-action{
    font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;
    text-transform:uppercase;color:var(--ink);font-weight:600;
    border-bottom:1px solid var(--ink);padding-bottom:3px;
    display:inline-block;transition:.2s;
  }
  .unit-row:hover .article-action{color:var(--brand);border-color:var(--brand)}

  /* ============ EMPTY STATE (籌備中分類) ============ */
  .empty-state{
    padding:var(--sp-10) 0;
    text-align:center;
    color:var(--muted);
  }
  .empty-state .e-lat{
    font-family:"IBM Plex Serif",sans-serif;
    font-size:var(--t-caption);
    letter-spacing:3px;
    text-transform:uppercase;
    color:var(--muted);
    margin-bottom:var(--sp-4);
    display:flex;align-items:center;justify-content:center;gap:var(--sp-4);
  }
  .empty-state .e-lat::before,.empty-state .e-lat::after{
    content:"";width:24px;height:1px;background:var(--line);
  }
  .empty-state h3{font-size:var(--t-title-l); letter-spacing:1.5px;
    color:#999;
    font-weight:500;
    margin-bottom:var(--sp-4);
    line-height:1.5;
  }
  .empty-state p{
    font-size:var(--t-body);
    color:var(--muted);
    line-height:1.85;
    max-width:480px;
    margin:0 auto;
    letter-spacing:0;
  }

  /* ============ COOKIE ============ */

  /* drawer 二級展開（公益行動 5 個子項） */
  .drawer-group{border-bottom:1px solid rgba(255,255,255,.1)}
  .drawer-group > .drawer-group-head{
    position:relative;
    padding:var(--sp-4) 0;
    font-size:var(--t-body-l);
    color:#fff;
    letter-spacing:3px;
    font-weight:500;
    transition:padding .25s;
    display:flex;align-items:center;gap:var(--sp-4);
    cursor:pointer;
    background:none;border:0;width:100%;text-align:left;
    font-family:inherit;
  }
  .drawer-group > .drawer-group-head::before{content:"";width:0;height:1px;background:#fff;transition:width .25s}
  .drawer-group.on > .drawer-group-head,
  .drawer-group > .drawer-group-head:hover{padding-left:var(--sp-2)}
  .drawer-group.on > .drawer-group-head::before,
  .drawer-group > .drawer-group-head:hover::before{width:24px}
  .drawer-group > .drawer-group-head .label{flex:1}
  .drawer-group > .drawer-group-head .caret{
    font-family:"IBM Plex Serif",sans-serif;
    font-size:var(--t-body);
    opacity:.7;
    transition:transform .25s;
  }
  .drawer-group.on > .drawer-group-head .caret{transform:rotate(180deg)}
  .drawer-group .drawer-group-body{
    max-height:0;
    overflow:hidden;
    transition:max-height .3s ease;
  }
  .drawer-group.on .drawer-group-body{max-height:360px}
  .drawer-group .drawer-group-body .sub-item{
    display:block;
    padding:var(--sp-3) 0 var(--sp-3) var(--sp-4);
    font-size:var(--t-body);
    color:rgba(255,255,255,.88);
    letter-spacing:2px;
    border:0;
    background:none;
    text-align:left;
    width:100%;
    font-family:inherit;
    cursor:pointer;
    border-bottom:1px solid rgba(255,255,255,.06);
    transition:color .2s,padding .2s;
  }
  .drawer-group .drawer-group-body .sub-item:last-child{border-bottom:none}
  .drawer-group .drawer-group-body .sub-item:hover{color:#fff;padding-left:var(--sp-5)}
  .drawer-group .drawer-group-body .sub-item.on{color:#fff;font-weight:700}
  .drawer-group .drawer-group-body .sub-item.todo{color:rgba(255,255,255,.5)}
  .drawer-group .drawer-group-body .sub-item.todo:hover{color:rgba(255,255,255,.75)}

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1100px){
    .sub-nav{padding:var(--sp-3) var(--sp-4) var(--sp-4)}
    .sub-nav .item{padding:0 var(--sp-4);letter-spacing:1px;font-size:11.5px}
    /* 短橫 1100 維持置中、寬度略縮 */
    .sub-nav .item.on::after{width:20px}

    .sub-nav{position:static}
    .page-hero{padding:var(--sp-7) 0 var(--sp-6)}
    .unit-row{grid-template-columns:480px 1fr;gap:var(--sp-7);padding:var(--sp-4);margin:0 -var(--sp-4) 3px}
    .unit-body{padding-right:0}
    .unit-body .title{font-size:var(--t-title);letter-spacing:1.5px}
    .donate-card{grid-template-columns:1fr;gap:var(--sp-7);padding:var(--sp-7);border-radius:4px}
    .donate-text{padding:0}
    .donate-stats{border-left:none;border-top:1px solid rgba(255,255,255,.2);padding-left:0;padding-top:var(--sp-6)}
  }
  @media (max-width: 720px){
    .sub-nav{display:none}    /* 手機不顯示 sub-nav，收進 drawer */

    .wrap{padding:0 var(--sp-4)}
    .page-hero{padding:var(--sp-7) 0 var(--sp-6)}
    .page-hero .lead{font-size:var(--t-body);line-height:1.85}
    .units-section{padding:var(--sp-6) 0 var(--sp-8)}
    .unit-row{grid-template-columns:1fr;gap:var(--sp-4);padding:var(--sp-4);margin:0 -var(--sp-4) 3px}
    .unit-body .title{font-size:var(--t-title);letter-spacing:1px;margin-bottom:var(--sp-4)}
    .unit-body .quote{font-size:var(--t-body);line-height:1.85;margin-bottom:var(--sp-4)}
    .donate-band{padding:var(--sp-7) var(--sp-4)}
    .donate-card{padding:var(--sp-6) var(--sp-5);gap:var(--sp-6)}
    .donate-text{padding:var(--sp-7) var(--sp-4)}
    .donate-stats{padding-top:var(--sp-5)}
    .empty-state{padding:var(--sp-9) var(--sp-4)}
    .empty-state h3{font-size:var(--t-title);letter-spacing:3px}
  }
</style>
{% endblock %}

{% block content %}
