---
permalink: shop.html
title: "公益小舖｜薛伯輝基金會"
active: shop
---
{% extends "base.njk" %}

{% block styles %}
<style>
  /* base · header · nav → app.css */

  /* ============ FEATURED（本月主打：威宏）============ */
  .featured{background:var(--brand-tint);padding:var(--sp-9) 0;border-bottom:1px solid #F0DADA}
  .featured-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:var(--sp-8);align-items:center}
  .featured-img{aspect-ratio:5/4;position:relative;overflow:hidden;background:linear-gradient(160deg,#5a0808,#1a0202);border-radius:2px}
  .featured-img .img-fill{position:absolute;inset:0;background:inherit;transition:transform .6s cubic-bezier(.25,.46,.45,.94)}
  .featured-img:hover .img-fill{transform:scale(1.04)}
  .featured-img::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(0,0,0,.42) 100%);pointer-events:none}
  .featured-img .ph-mark{position:absolute;bottom:18px;left:18px;z-index:2;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.72);font-weight:600}
  .featured-text .eyebrow{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:4px;text-transform:uppercase;color:var(--brand);font-weight:600;margin-bottom:var(--sp-4);display:flex;align-items:center;gap:var(--sp-4)}
  .featured-text .eyebrow::before{content:"";width:32px;height:1px;background:var(--brand)}
  .featured-text .maker-line{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:2px;color:var(--brand-dark);font-weight:500;margin-bottom:var(--sp-3)}
  .featured-text h1{font-size:var(--t-display);letter-spacing:1.5px;color:var(--ink);line-height:1.2;margin-bottom:var(--sp-5);font-weight:700}
  .featured-text .story{font-size:var(--t-body);color:var(--body);line-height:1.95;margin-bottom:var(--sp-6);max-width:520px;text-wrap:pretty}
  .featured-text .f-foot{display:flex;align-items:center;gap:var(--sp-6);flex-wrap:wrap}
  .featured-text .f-price{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-title);color:var(--brand-dark);font-weight:600;letter-spacing:.5px}
  .featured-text .actions{display:flex;gap:var(--sp-4);flex-wrap:wrap}
  .btn-fill{display:inline-flex;align-items:center;gap:var(--sp-2);padding:var(--sp-3) var(--sp-6);background:var(--brand);color:#fff;font-size:var(--t-body-s);letter-spacing:2px;font-weight:500;transition:background .2s}
  .btn-fill::after{content:"→";font-family:"IBM Plex Serif",sans-serif}
  .btn-fill:hover{background:var(--brand-dark)}
  .btn-line{display:inline-flex;align-items:center;gap:var(--sp-2);padding:var(--sp-3) var(--sp-6);border:1px solid var(--ink);color:var(--ink);font-size:var(--t-body-s);letter-spacing:2px;font-weight:500;transition:all .2s}
  .btn-line:hover{background:var(--ink);color:#fff}

  /* ============ SECTION HEAD ============ */
  .shop-list{padding:var(--sp-9) 0 var(--sp-10);background:#fff}
  .section-head{display:flex;justify-content:space-between;align-items:flex-end;border-bottom:1px solid var(--ink);padding-bottom:var(--sp-5);margin-bottom:var(--sp-8)}
  .section-head .titles{display:flex;flex-direction:column;gap:var(--sp-3)}
  .section-head .subtitle{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:3.5px;color:var(--brand);font-weight:600;text-transform:uppercase;display:flex;align-items:center;gap:var(--sp-4)}
  .section-head .subtitle::before{content:"";width:24px;height:1px;background:var(--brand)}
  .section-head h2.section-title{font-size:var(--t-section);font-weight:700;color:var(--ink);letter-spacing:1.5px;line-height:1.25}
  .section-head .head-note{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);color:var(--muted);letter-spacing:1.5px}

  /* ============ PRODUCT GRID ============ */
  .product-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--sp-8) var(--sp-6)}
  .p-card{display:flex;flex-direction:column;cursor:pointer}
  .p-thumb{aspect-ratio:4/5;overflow:hidden;position:relative;background:linear-gradient(135deg,#3a1818,#1a0202);margin-bottom:var(--sp-4)}
  .p-thumb .img-fill{position:absolute;inset:0;background:inherit;transition:transform .55s cubic-bezier(.25,.46,.45,.94)}
  .p-card:hover .p-thumb .img-fill{transform:scale(1.05)}
  .p-thumb::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(0,0,0,.45) 100%);pointer-events:none;z-index:1}
  .p-thumb .ph-mark{position:absolute;bottom:16px;left:16px;z-index:2;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.72);font-weight:600}
  .p-card .meta{display:flex;gap:var(--sp-3);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:var(--sp-3)}
  .p-card .meta .cat{color:var(--brand);font-weight:700}
  .p-card .title{font-size:var(--t-title);line-height:1.5;font-weight:700;letter-spacing:0;color:var(--ink);margin-bottom:var(--sp-3);transition:color .2s}
  .p-card:hover .title{color:var(--brand)}
  .p-line{font-size:var(--t-body);line-height:1.85;color:var(--body);margin:0 0 var(--sp-4);text-wrap:pretty}
  .p-foot{margin-top:auto;display:flex;justify-content:space-between;align-items:center;padding-top:var(--sp-4);border-top:1px solid var(--line)}
  .p-price{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-body);color:var(--brand-dark);font-weight:600;letter-spacing:.5px}
  .article-action{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--ink);font-weight:600;border-bottom:1px solid var(--ink);padding-bottom:3px;display:inline-block;transition:.2s}
  .p-card:hover .article-action{color:var(--brand);border-color:var(--brand)}

  /* donate band · footer · back-to-top · mobile drawer → app.css */

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1100px){
    .featured-grid{grid-template-columns:1fr;gap:var(--sp-6)}
    .featured-img{order:-1}
    .product-grid{grid-template-columns:repeat(2,1fr);gap:var(--sp-7) var(--sp-5)}
    .donate-card{grid-template-columns:1fr;gap:var(--sp-7);padding:var(--sp-7)}
    .donate-stats{border-left:none;border-top:1px solid rgba(255,255,255,.2);padding-left:0;padding-top:var(--sp-6)}
  }
  @media (max-width: 720px){
    .wrap{padding:0 var(--sp-4)}
    .featured{padding:var(--sp-7) 0}
    .featured-text h1{font-size:var(--t-display-l)}
    .product-grid{grid-template-columns:1fr;gap:var(--sp-7)}
    .p-thumb{aspect-ratio:3/2}
    .section-head{flex-direction:column;align-items:flex-start;gap:var(--sp-4)}
    .donate-band{padding:var(--sp-7) var(--sp-4)}
  }
</style>
{% endblock %}

{% block content %}
<!-- ===== FEATURED · 本月主打（威宏的紅包袋）===== -->
<section class="featured">
  <div class="wrap">
    <div class="featured-grid">
      <figure class="featured-img"><span class="img-fill"></span><span class="ph-mark">商品照片</span></figure>
      <div class="featured-text">
        <p class="eyebrow">本月主打 · Featured</p>
        <p class="maker-line">創作者 ｜ 威宏</p>
        <h1>威宏的紅包袋</h1>
        <p class="story">威宏用畫筆把心裡的世界畫出來，這些圖樣化成一張張紅包袋。每一筆收入，都回到威宏與基金會陪伴的孩子身上 —— 你送出的祝福，也成了他們繼續創作的力量。</p>
        <div class="f-foot">
          <span class="f-price">NT$ 280 起</span>
          <div class="actions">
            <a class="btn-fill" href="shop-weihong.html">我想支持</a>
            <a class="btn-line" href="shop-weihong.html">看威宏的故事</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== 全部商品 ===== -->
<section class="shop-list">
  <div class="wrap">
    <div class="section-head">
      <div class="titles">
        <h2 class="section-title">小舖裡的每一件好物</h2>
        <p class="subtitle"><span>All Goods</span></p>
      </div>
      <span class="head-note">文創品 · 出版品 · 公益合作商品</span>
    </div>
    <div class="product-grid" id="productGrid"></div>
  </div>
</section>

<!-- ===== DONATE BAND ===== -->
<section class="donate-band">
  <div class="wrap">
    <div class="donate-card">
      <div class="donate-text">
        <div class="label">Donate</div>
        <h2>捐款支持<br>愛與希望的延續</h2>
        <p>每一份支持，都將化為文化教育、特殊教育與公益行動的力量。基金會持續公開捐款徵信，讓愛與希望被妥善託付。</p>
        <div class="actions">
          <a class="btn-w" href="donate.html">捐款方式</a>
          <a class="btn-wo" href="donate.html">捐款徵信</a>
        </div>
      </div>
      <div class="donate-stats" aria-label="捐款方式摘要">
        <div class="donate-method">
          <span class="method-label">銀行匯款</span>
          <h3>銀行匯款 / ATM 轉帳</h3>
          <p>國泰世華 台北分行（銀行代碼 <b>013</b>）<br>帳號 <b>007-03-603896-3</b></p>
        </div>
        <div class="donate-method">
          <span class="method-label">郵政劃撥</span>
          <h3>郵局劃撥</h3>
          <p>帳號 <b>50067771</b><br>戶名 <b>財團法人薛伯輝基金會</b></p>
        </div>
        <div class="donate-method">
          <span class="method-label">其他方式</span>
          <h3>信用卡、支票與現場捐款</h3>
          <p>歡迎透過信用卡授權書、支票或親臨基金會現場捐款，捐款徵信定期公開。</p>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}

{% block scripts %}
<script>
// ===== 商品資料（佔位；威宏已置於上方主打，列表顯示其餘）=====
  const PRODUCTS = [
    {name:'地磨兒手繪明信片組', maker:'地磨兒國小',   cat:'文創品',     tagline:'山裡孩子的歌聲，化成一張張畫。', price:'NT$ 150', href:'#'},
    {name:'惠民鑼鼓班帆布袋',   maker:'惠民啟智中心', cat:'文創品',     tagline:'咚咚鼓聲裡，找到自信的天使們。', price:'NT$ 380', href:'#'},
    {name:'《愛與希望》紀念文集', maker:'薛伯輝基金會', cat:'出版品',    tagline:'二十年陪伴的故事，集結成冊。', price:'NT$ 350', href:'#'},
    {name:'瑞復手作煎餅禮盒',   maker:'瑞復益智中心', cat:'公益合作商品', tagline:'行動煎餅車上，最暖的滋味。', price:'NT$ 420', href:'#'},
    {name:'搖籃咖啡｜美濃精選豆', maker:'搖籃咖啡',   cat:'公益合作商品', tagline:'一杯咖啡，一次愛的循環。', price:'NT$ 450', href:'#'}
  ];
  const GRADS = ['linear-gradient(135deg,#a89070,#604530)','linear-gradient(135deg,#888,#3a3a3a)','linear-gradient(135deg,#c4a880,#704830)','linear-gradient(135deg,#5a3a2a,#1a1010)','linear-gradient(135deg,#8C0A0A,#3a1818)'];
  const grid = document.getElementById('productGrid');
  grid.innerHTML = PRODUCTS.map((p,i) => `
    <a class="p-card" href="${p.href}">
      <figure class="p-thumb" style="background:${GRADS[i % GRADS.length]}"><span class="img-fill"></span><span class="ph-mark">商品照片</span></figure>
      <div class="meta"><span class="cat">${p.cat}</span><span>${p.maker}</span></div>
      <h3 class="title">${p.name}</h3>
      <p class="p-line">${p.tagline}</p>
      <div class="p-foot"><span class="p-price">${p.price}</span><span class="article-action">我想支持 →</span></div>
    </a>`).join('');
</script>
{% endblock %}
