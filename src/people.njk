{% block scripts %}
<script>
  // ============ HERO 輪播（淡入淡出 + 圓點 + 自動 5s，無箭頭，滑入暫停）============
  (function(){
    var hero = document.getElementById('phHero');
    if (!hero) return;
    var slides = hero.querySelectorAll('.hero-slide');
    var dotsBox = document.getElementById('phDots');
    if (slides.length < 2 || !dotsBox) return;
    var idx = 0, timer;
    var dots = Array.prototype.map.call(slides, function(_, i){
      var b = document.createElement('button');
      b.type = 'button';
      b.setAttribute('aria-label', '第 ' + (i + 1) + ' 張');
      if (i === 0) b.className = 'on';
      b.addEventListener('click', function(){ go(i); reset(); });
      dotsBox.appendChild(b);
      return b;
    });
    function go(n){
      idx = (n + slides.length) % slides.length;
      for (var i = 0; i < slides.length; i++){
        slides[i].classList.toggle('on', i === idx);
        dots[i].classList.toggle('on', i === idx);
      }
    }
    function reset(){ clearInterval(timer); timer = setInterval(function(){ go(idx + 1); }, 5000); }
    hero.addEventListener('mouseenter', function(){ clearInterval(timer); });
    hero.addEventListener('mouseleave', reset);
    reset();
  })();
</script>
{% endblock %}
