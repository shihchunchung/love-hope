{% block styles %}
<style>
  /* ============ SUB-NAV（真愛多多 cluster・跨頁，比照徵信頁）============ */
  .sub-nav{background:#fff;position:sticky;top:140px;z-index:48;display:flex;justify-content:center;align-items:stretch;padding:var(--sp-3) var(--sp-6);flex-wrap:wrap;border-bottom:1px solid var(--line);font-family:"IBM Plex Serif",sans-serif}
  .sub-nav .item{padding:var(--sp-3) var(--sp-5);font-size:var(--t-body-s);letter-spacing:2px;color:#666;font-weight:500;position:relative;cursor:pointer;transition:color .18s;background:none;border:0;font-family:inherit;text-decoration:none}
  .sub-nav .item:hover{color:var(--brand)}
  .sub-nav .item.todo{color:#BBB;cursor:default}
  .sub-nav .item.todo:hover{color:#BBB}
  .sub-nav .item.on{color:var(--brand);font-weight:700}
  .sub-nav .item.on::after{content:"";position:absolute;left:50%;transform:translateX(-50%);bottom:-1px;width:24px;height:2px;background:var(--brand)}

  /* ============ HERO CAROUSEL（淡入淡出）============ */
  .story-hero{position:relative;height:clamp(360px,52vh,560px);background:#0f0f0f;overflow:hidden}
  .story-hero .hero-slide{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 42%;opacity:0;transition:opacity .8s ease}
  .story-hero .hero-slide.on{opacity:1}
  .story-hero::after{content:"";position:absolute;inset:0;z-index:2;background:linear-gradient(180deg,rgba(0,0,0,.15) 0,transparent 28%,transparent 60%,rgba(0,0,0,.45) 100%);pointer-events:none}
  .story-hero .hero-dots{position:absolute;bottom:18px;left:0;right:0;z-index:3;display:flex;gap:10px;justify-content:center}
  .story-hero .hero-dots button{width:9px;height:9px;border-radius:50%;border:0;padding:0;background:rgba(255,255,255,.45);cursor:pointer;transition:background .2s,transform .2s}
  .story-hero .hero-dots button:hover{background:rgba(255,255,255,.75)}
  .story-hero .hero-dots button.on{background:#fff;transform:scale(1.25)}

  /* ============ STORY TITLE ============ */
  .story-title{padding:var(--sp-8) 0 var(--sp-7);background:#fff;border-bottom:1px solid var(--line-soft)}
  .story-title .story-h1{
    font-size:var(--t-display-l);letter-spacing:1.5px;line-height:1.25;
    color:var(--ink);margin-bottom:0;font-weight:700;max-width:900px;
  }

  /* ============ STORY BODY（編輯閱讀區）============ */
  .story-body{padding:var(--sp-8) 0 var(--sp-9);background:#fff}
  .story-body .body-col{max-width:760px}
  .story-body p{
    font-size:var(--t-body-l);line-height:1.95;color:var(--body);
    margin-bottom:1.4em;letter-spacing:0;
  }
  .story-body .sec-h{
    font-size:var(--t-title);letter-spacing:1px;color:var(--ink);
    margin:var(--sp-8) 0 var(--sp-5);display:flex;align-items:center;gap:var(--sp-4);font-weight:700;
  }
  .story-body .sec-h::before{content:"";width:32px;height:1px;background:var(--brand);flex-shrink:0}
  /* 建築概要：key-value 規格表 */
  .story-body dl.spec-list{
    margin:0 0 1.4em;display:grid;grid-template-columns:max-content 1fr;
    gap:0;border-top:1px solid var(--line);
  }
  .story-body dl.spec-list dt{
    color:var(--brand);font-weight:700;letter-spacing:1px;white-space:nowrap;
    font-size:var(--t-body);padding:var(--sp-3) var(--sp-6) var(--sp-3) 0;
    border-bottom:1px solid var(--line);
  }
  .story-body dl.spec-list dd{
    color:var(--ink);margin:0;font-size:var(--t-body);line-height:1.7;
    padding:var(--sp-3) 0;border-bottom:1px solid var(--line);
  }

  /* ============ DONATE BAND RWD（chrome 樣式在 app.css，RWD 仍由頁面帶）============ */
  @media (max-width: 1100px){
    .sub-nav{padding:var(--sp-3) var(--sp-4);position:static}
    .sub-nav .item{padding:var(--sp-3) var(--sp-4);letter-spacing:1.5px}
    .sub-nav .item.on::after{width:20px}
    .story-hero{height:clamp(320px,45vh,460px)}
    .story-title{padding:var(--sp-7) 0 var(--sp-6)}
    .story-body{padding:var(--sp-7) 0 var(--sp-9)}
    .donate-card{grid-template-columns:1fr;gap:var(--sp-7);padding:var(--sp-7);border-radius:4px}
    .donate-text{padding:0}
    .donate-stats{border-left:none;border-top:1px solid rgba(255,255,255,.2);padding-left:0;padding-top:var(--sp-6)}
  }
  @media (max-width: 720px){
    .sub-nav{padding:var(--sp-2) var(--sp-3)}
    .sub-nav .item{padding:var(--sp-2) var(--sp-3);font-size:var(--t-meta);letter-spacing:1px}
    .wrap{padding:0 var(--sp-4)}
    .story-hero{height:280px}
    .story-title{padding:var(--sp-7) 0 var(--sp-6)}
    .story-title .story-h1{font-size:var(--t-display);letter-spacing:1.5px}
    .story-body{padding:var(--sp-6) 0 var(--sp-8)}
    .story-body p{font-size:var(--t-body);line-height:1.9}
    .story-body .sec-h{margin:var(--sp-6) 0 var(--sp-4);font-size:var(--t-title-s)}
    .story-body dl.spec-list{grid-template-columns:1fr;gap:0}
    .story-body dl.spec-list dt{border-bottom:0;padding-bottom:0;padding-top:var(--sp-4)}
    .story-body dl.spec-list dd{padding-top:2px}
    .donate-band{padding:var(--sp-7) var(--sp-4)}
    .donate-card{padding:var(--sp-6) var(--sp-5);gap:var(--sp-6)}
    .donate-stats{padding-top:var(--sp-5)}
  }
</style>
