{% block scripts %}
<script>
// ===== 商品照片（佔位漸層；之後換成 images/shop/ 內真實照片）=====
  const GRADS = [
    'linear-gradient(135deg,#8C0A0A,#3a1010)',
    'linear-gradient(135deg,#a8454a,#5C0606)',
    'linear-gradient(135deg,#c4a880,#704830)',
    'linear-gradient(135deg,#3a3a3a,#0f0f0f)'
  ];
  const CAP = '威宏的紅包袋 ｜ 商品照片';
  const main = document.getElementById('pdMain');
  const thumbsWrap = document.getElementById('pdThumbs');
  let active = 0;
  function setActive(i){
    active = i;
    main.style.background = GRADS[i];
    thumbsWrap.querySelectorAll('.pd-thumb').forEach((t,k)=>t.classList.toggle('on', k===i));
  }
  GRADS.forEach((g,i)=>{
    const t = document.createElement('div');
    t.className = 'pd-thumb' + (i===0?' on':'');
    t.style.background = g;
    t.setAttribute('role','button');
    t.setAttribute('aria-label','照片 '+(i+1));
    t.addEventListener('click', ()=>setActive(i));
    thumbsWrap.appendChild(t);
  });
  setActive(0);

  // ===== 燈箱 =====
  const lb = document.getElementById('lightbox');
  const lbStage = document.getElementById('lbStage');
  const lbCap = document.getElementById('lbCap');
  let lbMode = 'product';
  function renderLb(){
    if (lbMode === 'story'){
      lbStage.style.background = 'linear-gradient(135deg,#5a3a2a,#1a1010)';
      lbStage.style.aspectRatio = '4/3';
      lbCap.textContent = '威宏 ｜ 創作者照片';
    } else {
      lbStage.style.background = GRADS[active];
      lbStage.style.aspectRatio = '4/5';
      lbCap.textContent = CAP;
    }
  }
  function openLb(mode){ lbMode = mode; renderLb(); lb.classList.add('on'); document.body.style.overflow='hidden'; }
  function closeLb(){ lb.classList.remove('on'); document.body.style.overflow=''; }
  main.addEventListener('click', ()=>openLb('product'));
  main.addEventListener('keydown', e=>{ if(e.key==='Enter'||e.key===' '){e.preventDefault();openLb('product');} });
  document.querySelector('.story-photo').addEventListener('click', ()=>openLb('story'));
  document.querySelector('.story-photo').addEventListener('keydown', e=>{ if(e.key==='Enter'||e.key===' '){e.preventDefault();openLb('story');} });
  function lbStep(d){ if(lbMode!=='product') return; setActive((active+d+GRADS.length)%GRADS.length); renderLb(); }
  document.getElementById('lbClose').addEventListener('click', closeLb);
  document.getElementById('lbPrev').addEventListener('click', ()=>lbStep(-1));
  document.getElementById('lbNext').addEventListener('click', ()=>lbStep(1));
  lb.addEventListener('click', e=>{ if(e.target===lb) closeLb(); });
  document.addEventListener('keydown', e=>{
    if(!lb.classList.contains('on')) return;
    if(e.key==='Escape') closeLb();
    if(e.key==='ArrowLeft') lbStep(-1);
    if(e.key==='ArrowRight') lbStep(1);
  });
</script>
{% endblock %}
