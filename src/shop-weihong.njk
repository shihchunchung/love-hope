---
permalink: shop-weihong.html
title: "威宏的紅包袋｜公益小舖 — 薛伯輝基金會"
active: shop
---
{% extends "base.njk" %}

{% block styles %}
<style>
  /* ============ BREADCRUMB ============ */
  .pd-crumb{border-bottom:1px solid var(--line-soft);background:#fff}
  .pd-crumb .wrap{display:flex;align-items:center;gap:var(--sp-3);padding-top:var(--sp-4);padding-bottom:var(--sp-4)}
  .pd-crumb a,.pd-crumb span{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2px;text-transform:uppercase;color:var(--muted)}
  .pd-crumb a{transition:color .2s}
  .pd-crumb a:hover{color:var(--brand)}
  .pd-crumb .arr{color:var(--line)}
  .pd-crumb .cur{color:var(--ink);font-weight:600}

  /* ============ PRODUCT HERO ============ */
  .pd{padding:var(--sp-8) 0 var(--sp-9);background:#fff}
  .pd-grid{display:grid;grid-template-columns:1.02fr .98fr;gap:var(--sp-8);align-items:start}
  .pd-main{aspect-ratio:4/5;position:relative;overflow:hidden;background:linear-gradient(135deg,#8C0A0A,#3a1010);cursor:zoom-in}
  .pd-main::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(0,0,0,.45) 100%);pointer-events:none;z-index:1}
  .pd-main .ph-mark{position:absolute;bottom:18px;left:18px;z-index:2;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.72);font-weight:600}
  .pd-thumbs{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--sp-3);margin-top:var(--sp-3)}
  .pd-thumb{aspect-ratio:1/1;position:relative;overflow:hidden;cursor:pointer;opacity:.62;outline:2px solid transparent;outline-offset:-2px;transition:opacity .2s,outline-color .2s}
  .pd-thumb:hover{opacity:.85}
  .pd-thumb.on{opacity:1;outline-color:var(--brand)}

  .pd-info{padding-top:var(--sp-2)}
  .pd-eyebrow{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:4px;text-transform:uppercase;color:var(--brand);font-weight:600;margin-bottom:var(--sp-4);display:flex;align-items:center;gap:var(--sp-4)}
  .pd-eyebrow::before{content:"";width:32px;height:1px;background:var(--brand)}
  .pd-info h1{font-size:var(--t-display);letter-spacing:1.5px;color:var(--ink);line-height:1.18;margin-bottom:var(--sp-3);font-weight:700}
  .pd-maker{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:2px;color:var(--brand-dark);font-weight:500;margin-bottom:var(--sp-5)}
  .pd-price{display:block;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-title-l);color:var(--brand-dark);font-weight:600;letter-spacing:.5px;margin-bottom:var(--sp-5)}
  .pd-desc{font-size:var(--t-body);color:var(--body);line-height:1.95;margin-bottom:var(--sp-6);max-width:480px;text-wrap:pretty}
  .pd-chips{display:flex;flex-wrap:wrap;gap:var(--sp-2) var(--sp-3);margin-bottom:var(--sp-6)}
  .pd-chips .chip{font-size:var(--t-meta);letter-spacing:1px;color:var(--brand-dark);background:var(--brand-tint);padding:var(--sp-1) var(--sp-3);font-weight:600;border-radius:2px}
  .pd-actions{display:flex;gap:var(--sp-4);flex-wrap:wrap;align-items:center;padding-top:var(--sp-6);border-top:1px solid var(--line)}
  .btn-fill{display:inline-flex;align-items:center;gap:var(--sp-2);padding:var(--sp-4) var(--sp-7);background:var(--brand);color:#fff;font-size:var(--t-body-s);letter-spacing:2px;font-weight:500;transition:background .2s}
  .btn-fill::after{content:"→";font-family:"IBM Plex Serif",sans-serif}
  .btn-fill:hover{background:var(--brand-dark)}
  .btn-line{display:inline-flex;align-items:center;gap:var(--sp-2);padding:var(--sp-4) var(--sp-6);border:1px solid var(--ink);color:var(--ink);font-size:var(--t-body-s);letter-spacing:2px;font-weight:500;transition:all .2s}
  .btn-line:hover{background:var(--ink);color:#fff}
  .pd-note{font-size:var(--t-caption);color:var(--muted);letter-spacing:.5px;margin-top:var(--sp-4);line-height:1.7}

  /* ============ STORY ============ */
  .story{padding:var(--sp-10) 0;background:var(--line-soft);border-top:1px solid var(--line-soft)}
  .story-row{display:grid;grid-template-columns:.92fr 1.08fr;gap:var(--sp-8);align-items:center}
  .story-text .eyebrow{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:4px;text-transform:uppercase;color:var(--brand);font-weight:600;margin-bottom:var(--sp-4);display:flex;align-items:center;gap:var(--sp-4)}
  .story-text .eyebrow::before{content:"";width:32px;height:1px;background:var(--brand)}
  .story-text h2{font-size:var(--t-section);letter-spacing:1.5px;color:var(--ink);line-height:1.25;margin-bottom:var(--sp-5);font-weight:700}
  .story-text p{font-size:var(--t-body);color:var(--body);line-height:1.95;margin-bottom:var(--sp-5);text-wrap:pretty}
  .story-text p:last-child{margin-bottom:0}
  .story-text .pull{color:var(--brand-dark);font-weight:600}
  .story-photo{aspect-ratio:4/3;position:relative;overflow:hidden;background:linear-gradient(135deg,#5a3a2a,#1a1010);cursor:zoom-in}
  .story-photo::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 60%,rgba(0,0,0,.4) 100%)}
  .story-photo .ph-mark{position:absolute;bottom:18px;left:18px;z-index:2;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.72);font-weight:600}

  /* ============ SPECS ============ */
  .specs{padding:var(--sp-9) 0;background:#fff}
  .sec-head{display:flex;align-items:flex-end;justify-content:space-between;border-bottom:1px solid var(--ink);padding-bottom:var(--sp-5);margin-bottom:var(--sp-7)}
  .sec-head .subtitle{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:3.5px;color:var(--brand);font-weight:600;text-transform:uppercase;display:flex;align-items:center;gap:var(--sp-4);margin-top:var(--sp-3);order:2}
  .sec-head .subtitle::before{content:"";width:24px;height:1px;background:var(--brand)}
  .sec-head .titles{display:flex;flex-direction:column;gap:var(--sp-3)}
  .sec-head h2{font-size:var(--t-section);font-weight:700;color:var(--ink);letter-spacing:1.5px;line-height:1.25}
  .spec-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--sp-5) var(--sp-8)}
  .spec{display:flex;justify-content:space-between;align-items:baseline;gap:var(--sp-4);padding-bottom:var(--sp-4);border-bottom:1px dashed var(--line)}
  .spec .k{font-size:var(--t-body-s);color:var(--muted);letter-spacing:1px;white-space:nowrap}
  .spec .v{font-size:var(--t-body-s);color:var(--ink);font-weight:500;text-align:right}

  /* ============ SUPPORT ============ */
  .support{padding:var(--sp-9) 0;background:var(--brand-tint);border-top:1px solid #F0DADA}
  .support .wrap{max-width:680px;text-align:center}
  .support .eyebrow{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:4px;text-transform:uppercase;color:var(--brand);font-weight:600;margin-bottom:var(--sp-4);display:inline-flex;align-items:center;gap:var(--sp-4)}
  .support .eyebrow::before,.support .eyebrow::after{content:"";width:24px;height:1px;background:var(--brand)}
  .support h2{font-size:var(--t-title-l);letter-spacing:1px;color:var(--ink);line-height:1.4;margin-bottom:var(--sp-4);font-weight:700}
  .support p{font-size:var(--t-body);color:var(--body);line-height:1.9;margin-bottom:var(--sp-6);text-wrap:pretty}
  .support .ways{display:flex;gap:var(--sp-4);justify-content:center;flex-wrap:wrap}

  /* ============ LIGHTBOX ============ */
  .lightbox{position:fixed;inset:0;background:rgba(10,4,4,.95);z-index:100;display:none;align-items:center;justify-content:center}
  .lightbox.on{display:flex}
  .lightbox figure{max-width:92vw;max-height:88vh;display:flex;flex-direction:column;align-items:center;gap:var(--sp-4)}
  .lb-stage{width:min(72vh,88vw);aspect-ratio:4/5;max-width:88vw;box-shadow:0 20px 60px rgba(0,0,0,.5)}
  .lightbox figcaption{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:1.5px;color:rgba(255,255,255,.72)}
  .lb-btn{position:absolute;width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,.12);color:#fff;display:flex;align-items:center;justify-content:center;font-size:26px;line-height:1;transition:background .2s;z-index:2}
  .lb-btn:hover{background:rgba(255,255,255,.25)}
  .lb-close{top:24px;right:24px;font-family:"IBM Plex Serif",sans-serif}
  .lb-prev{left:24px;top:50%;transform:translateY(-50%)}
  .lb-next{right:24px;top:50%;transform:translateY(-50%)}

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1100px){
    .app-nav,.app-header{position:static}
    .pd-grid{grid-template-columns:1fr;gap:var(--sp-6);max-width:620px;margin:0 auto}
    .story-row{grid-template-columns:1fr;gap:var(--sp-6)}
    .story-photo{order:-1}
    .donate-card{grid-template-columns:1fr;gap:var(--sp-7);padding:var(--sp-7)}
    .donate-stats{border-left:none;border-top:1px solid rgba(255,255,255,.2);padding-left:0;padding-top:var(--sp-6)}
  }
  @media (max-width: 720px){
    .app-header .row{grid-template-columns:auto 1fr auto;gap:var(--sp-4);padding:var(--sp-4) var(--sp-4)}
    .header-socials,.header-utility{display:none}
    .donate-btn{padding:var(--sp-2) var(--sp-4);font-size:var(--t-meta);letter-spacing:2px}
    .app-nav{display:none}
    .nav-toggle{display:flex}
    .wrap{padding:0 var(--sp-4)}
    .pd-info h1{font-size:var(--t-display-l)}
    .spec-grid{grid-template-columns:1fr}
    .sec-head{flex-direction:column;align-items:flex-start;gap:var(--sp-4)}
    .donate-band{padding:var(--sp-7) var(--sp-4)}
  }
</style>
{% endblock %}

