---
permalink: news.html
title: "最新消息 — 薛伯輝基金會"
active: news
---
{% extends "base.njk" %}

{% block styles %}
<style>
  [hidden]{display:none !important}

  /* ============ SUB-NAV (年份 tabs) ============ */
  .sub-nav{background:#fff;position:sticky;top:140px;z-index:48;display:flex;justify-content:center;align-items:stretch;padding:var(--sp-3) var(--sp-6);flex-wrap:wrap;border-bottom:1px solid var(--line);font-family:"IBM Plex Serif",sans-serif}
  .sub-nav .item{padding:var(--sp-3) var(--sp-5);font-size:var(--t-body-s);letter-spacing:2px;color:#666;font-weight:500;position:relative;cursor:pointer;transition:color .18s;background:none;border:0;font-family:inherit;text-decoration:none}
  .sub-nav .item:hover{color:var(--brand)}
  .sub-nav .item.on{color:var(--brand);font-weight:700}
  .sub-nav .item.on::after{content:"";position:absolute;left:50%;transform:translateX(-50%);bottom:-1px;width:24px;height:2px;background:var(--brand)}

  /* ============ LIST SECTION ============ */
  .list-section{padding:var(--sp-8) 0 var(--sp-10);background:#fff}

  /* ===== 置頂區塊 ===== */
  .pinned-header{display:flex;align-items:baseline;justify-content:space-between;border-bottom:1px solid var(--ink);padding-bottom:var(--sp-4);margin-bottom:var(--sp-6)}
  .pinned-header h2{font-size:var(--t-title);font-weight:700;letter-spacing:1.5px;color:var(--ink);display:flex;align-items:center;gap:var(--sp-3)}
  .pinned-header h2::before{content:"";display:inline-block;width:28px;height:28px;background:url('images/lucky-clover.jpg') center/contain no-repeat;flex-shrink:0}
  .pinned-header .count{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;color:var(--muted);font-weight:600;text-transform:uppercase}
  .pinned-divider{height:1px;background:var(--line);margin:var(--sp-8) 0 var(--sp-6)}
  .list-header{display:flex;align-items:baseline;justify-content:space-between;border-bottom:1px solid var(--ink);padding-bottom:var(--sp-4);margin-bottom:var(--sp-6)}
  .list-header h2{font-size:var(--t-title);font-weight:700;letter-spacing:1.5px;color:var(--ink)}
  .list-header .count{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;color:var(--muted);font-weight:600;text-transform:uppercase}

  /* ===== 大列表 row (跟 actions.html 同尺寸：720×405 16:9) ===== */
  .news-list{display:flex;flex-direction:column}
  .news-row{
    display:grid;grid-template-columns:720px 1fr;gap:var(--sp-8);
    padding:var(--sp-4);margin:0 -var(--sp-4) var(--sp-1);
    align-items:center;transition:background .2s;text-decoration:none;color:inherit;
    position:relative;
  }
  .news-row:hover{background:var(--line-soft)}
  .news-image{aspect-ratio:16/9;overflow:hidden;position:relative;background:linear-gradient(135deg,#3a3a3a,#0f0f0f)}
  .news-image .img-fill{position:absolute;inset:0;background:inherit;transition:transform .55s cubic-bezier(.25,.46,.45,.94)}
  .news-row:hover .news-image .img-fill{transform:scale(1.05)}
  .news-image::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 60%,rgba(0,0,0,.4) 100%);pointer-events:none;z-index:1}
  /* 不同分類給不同 hue, 一致 placeholder 樣式 */
  .news-row[data-cat="announcement"] .news-image{background:linear-gradient(135deg,#5a0808,#1a0202)}
  .news-row[data-cat="exhibition"]   .news-image{background:linear-gradient(135deg,#3a3a3a,#0a0a0a)}
  .news-row[data-cat="literature"]   .news-image{background:linear-gradient(135deg,#604530,#2a1808)}
  .news-row[data-cat="podcast"]      .news-image{background:linear-gradient(135deg,#3a2828,#1a0808)}
  .news-row[data-cat="meinong"]      .news-image{background:linear-gradient(135deg,#a89070,#604530)}
  .news-row[data-cat="true-love"]    .news-image{background:linear-gradient(135deg,#5a3a2a,#1a1010)}
  .news-row[data-cat="charity"]      .news-image{background:linear-gradient(135deg,#704830,#2a1a0a)}
  .news-row[data-cat="lecture"]      .news-image{background:linear-gradient(135deg,#888,#3a3a3a)}

  .news-body{min-width:0;padding-right:var(--sp-5)}
  .news-body .meta{display:flex;gap:var(--sp-3);align-items:center;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);margin-bottom:var(--sp-4)}
  .news-body .meta .cat{color:var(--brand);font-weight:700}
  .news-body .meta .sep{color:var(--line)}
  .news-body .title{font-size:var(--t-title);line-height:1.5;font-weight:700;letter-spacing:1px;color:var(--ink);margin-bottom:var(--sp-4);transition:color .2s;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .news-row:hover .title{color:var(--brand)}
  .news-body .article-action{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--ink);font-weight:600;border-bottom:1px solid var(--ink);padding-bottom:3px;display:inline-block;transition:.2s}
  .news-row:hover .article-action{color:var(--brand);border-color:var(--brand)}

  /* ===== 圖片：混合策略 — 有圖→漸層 placeholder, 沒圖→文字卡 ===== */
  .news-row[data-has-image="0"] .news-image{background:#F8F4EE !important;display:flex;align-items:center;justify-content:center;padding:var(--sp-5)}
  .news-row[data-has-image="0"] .news-image::after{display:none}
  .news-row[data-has-image="0"] .news-image::before{content:attr(data-cat-label);color:var(--brand);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:3px;text-transform:uppercase;font-weight:700;z-index:2}

  /* ===== Load more ===== */
  .load-more-wrap{display:flex;justify-content:center;margin-top:var(--sp-7)}
  .load-more-btn{display:inline-flex;align-items:center;gap:var(--sp-3);justify-content:center;padding:var(--sp-3) var(--sp-7);border:1px solid var(--ink);color:var(--ink);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:3px;text-transform:uppercase;font-weight:600;transition:all .2s;background:#fff}
  .load-more-btn::after{content:"→"}
  .load-more-btn:hover{background:var(--ink);color:#fff}

  /* ===== Empty state ===== */
  .empty-state{padding:var(--sp-10) 0;text-align:center;color:var(--muted)}
  .empty-state .e-lat{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:var(--sp-4);display:flex;align-items:center;justify-content:center;gap:var(--sp-4)}
  .empty-state .e-lat::before,.empty-state .e-lat::after{content:"";width:24px;height:1px;background:var(--line)}
  .empty-state h3{font-size:var(--t-title-l);letter-spacing:1.5px;color:#999;font-weight:500;margin-bottom:var(--sp-4);line-height:1.5}
  .empty-state p{font-size:var(--t-body);color:var(--muted);line-height:1.85;max-width:480px;margin:0 auto;letter-spacing:0}

  /* ============ COOKIE ============ */

  .drawer-nav a.is-external:hover .ext-mark{transform:translate(2px,-2px);opacity:1}

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1100px){
    .sub-nav{padding:var(--sp-3) var(--sp-4)}
    .sub-nav .item{padding:var(--sp-3) var(--sp-4);letter-spacing:1.5px}
    .sub-nav .item.on::after{width:20px}
    .sub-nav{position:static}
    .news-row{grid-template-columns:480px 1fr;gap:var(--sp-7)}
    .news-body{padding-right:0}
    .news-body .title{font-size:var(--t-title);letter-spacing:1.5px}
    .donate-card{grid-template-columns:1fr;gap:var(--sp-7);padding:var(--sp-7)}
    .donate-stats{border-left:0;border-top:1px solid rgba(255,255,255,.2);padding-left:0;padding-top:var(--sp-6)}
  }
  @media (max-width: 720px){
    .sub-nav{display:none}

    .wrap{padding:0 var(--sp-4)}
    .list-section{padding:var(--sp-6) 0 var(--sp-8)}
    .news-row{grid-template-columns:1fr;gap:var(--sp-4);padding:var(--sp-4);margin:0 -var(--sp-4) 3px}
    .news-body .title{font-size:var(--t-title);letter-spacing:1px;margin-bottom:var(--sp-4)}
    .donate-band{padding:var(--sp-7) var(--sp-4)}
    .donate-card{padding:var(--sp-6) var(--sp-5);gap:var(--sp-6)}
    .empty-state{padding:var(--sp-9) var(--sp-4)}
  }
</style>
{% endblock %}

{% block content %}
<h1 class="sr-only">最新消息</h1>
<!-- ===== SUB-NAV (年份 tabs) ===== -->
<nav class="sub-nav" id="yearNav" aria-label="年份">
  <a class="item on" href="#all"  data-year="all">全部</a>
  <a class="item"    href="#2024" data-year="2024">2024</a>
  <a class="item"    href="#2022" data-year="2022">2022</a>
  <a class="item"    href="#2018" data-year="2018">2018</a>
  <a class="item"    href="#2017" data-year="2017">2017</a>
  <a class="item"    href="#2016" data-year="2016">2016</a>
  <a class="item"    href="#2015" data-year="2015">2015</a>
  <a class="item"    href="#2014" data-year="2014">2014</a>
</nav>

<!-- ===== LIST SECTION ===== -->
<section class="list-section">
  <div class="wrap">

    <!-- 置頂區塊 — 全站置頂永遠最上, 不受年份過濾 -->
    <div class="pinned-block" id="pinnedBlock">
      <div class="pinned-header">
        <h2>置頂消息 <span class="count" id="pinnedCount"></span></h2>
      </div>
      <div class="news-list" id="pinnedList"></div>
      <div class="pinned-divider"></div>
    </div>

    <!-- 一般列表 — 受年份過濾 -->
    <div class="list-block">
      <div class="list-header">
        <h2 id="listTitle">全部消息</h2>
        <span class="count" id="listCount"></span>
      </div>
      <div class="news-list" id="newsList"></div>
      <div class="empty-state" id="emptyState" hidden>
        <p class="e-lat">No Items</p>
        <h3>此年份目前無消息</h3>
        <p>請切換其他年份，或檢視「全部」消息。</p>
      </div>
      <div class="load-more-wrap" id="loadMoreWrap" hidden>
        <button class="load-more-btn" id="loadMoreBtn">看更多</button>
      </div>
    </div>

  </div>
</section>

<!-- ===== DONATE BAND ===== -->
<section class="donate-band">
  <div class="wrap">
    <div class="donate-card">
      <div class="donate-text">
        <div class="label">Donate</div>
        <h2>捐款支持<br>愛與希望的延續</h2>
        <p>每一份支持，都將化為文化教育、特殊教育與公益行動的力量。基金會持續公開捐款徵信，讓愛與希望被妥善託付。</p>
        <div class="actions">
          <a class="btn-w" href="donate.html">捐款方式</a>
          <a class="btn-wo" href="donate.html">捐款徵信</a>
        </div>
      </div>
      <div class="donate-stats" aria-label="捐款方式摘要">
        <div class="donate-method">
          <span class="method-label">Bank Transfer</span>
          <h3>銀行匯款 / ATM 轉帳</h3>
          <p>國泰世華 台北分行（銀行代碼 <b>013</b>）<br>帳號 <b>007-03-603896-3</b></p>
        </div>
        <div class="donate-method">
          <span class="method-label">Postal Giro</span>
          <h3>郵局劃撥</h3>
          <p>帳號 <b>50067771</b><br>戶名 <b>財團法人薛伯輝基金會</b></p>
        </div>
        <div class="donate-method">
          <span class="method-label">Other Ways</span>
          <h3>信用卡、支票與現場捐款</h3>
          <p>歡迎透過信用卡授權書、支票或親臨基金會現場捐款，捐款徵信定期公開。</p>
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}

{% block scripts %}
<script>
/* ============================================================
     CMS mock data — 對應後台資料結構
     Shape: { id, date(ISO), cat, title, image?(url), excerpt?, isPinned, pinOrder }
     ============================================================ */
  const CATEGORY_LABELS = {
    announcement: '公告',
    exhibition:   '共融藝術展',
    literature:   '文學閱讀月',
    podcast:      'Podcast',
    meinong:      '美濃 / 搖籃',
    'true-love':  '真愛多多',
    charity:      '公益行動',
    lecture:      '愛的講堂',
  };

  /* image: true = 有真實照片（CMS 上有上圖）; 無 image 欄位 = 純文字（公告/Podcast/online 講座） */
  const NEWS_ITEMS = [
    { id:'2024-merge',           date:'2024-11-06', cat:'announcement', title:'【公告】蔡紹華慈善濟助事業基金會併入本會', isPinned:true,  pinOrder:1 },
    { id:'2022-blackwhite',      date:'2022-12-23', cat:'exhibition',   title:'【共融藝術展】白與黑—王俠軍與原生藝術家', isPinned:true,  pinOrder:2, image:true },
    { id:'2022-yangmu-meinong',  date:'2022-12-21', cat:'meinong',      title:'楊牧書房在美濃', image:true },
    { id:'2022-yangmu-pod',      date:'2022-12-14', cat:'podcast',      title:'【Podcast】《楊牧的山風海雨》' },
    { id:'2022-yangmu-online',   date:'2022-12-11', cat:'literature',   title:'線上閱讀楊牧老師 須文蔚老師與談' },
    { id:'2022-zhongli',         date:'2022-11-29', cat:'literature',   title:'從鍾理和的天地書齋到楊牧書房', image:true },
    { id:'2022-yangmu-lecture',  date:'2022-11-28', cat:'literature',   title:'【線上講座資訊】楊牧的山風海雨', image:true },
    { id:'2022-huaxuan',         date:'2022-10-13', cat:'lecture',      title:'【課程資訊】繁花盛景的花園街景', image:true },
    { id:'2022-cradle-yc',       date:'2022-09-18', cat:'meinong',      title:'【講座資訊】我把辦公室變搖籃! 搖籃場', image:true },
    { id:'2022-cradle-ks',       date:'2022-09-06', cat:'meinong',      title:'【講座資訊】我把辦公室變搖籃! 高市圖場', image:true },
    { id:'2022-hakka',           date:'2022-07-28', cat:'lecture',      title:'【講座資訊】你是最後一代的客家人嗎？', image:true },
    { id:'2022-zhengchouyu',     date:'2022-07-22', cat:'literature',   title:'【文學＆共融藝術展】詩人 鄭愁予＆一樣的美', image:true },
    { id:'2022-zhengchouyu-pod', date:'2022-07-08', cat:'podcast',      title:'【Podcast】《鄭愁予的浪子傳奇》' },
    { id:'2022-yaxian-pod',      date:'2022-06-20', cat:'podcast',      title:'【Podcast】《瘂弦的遠方與家鄉》' },
    { id:'2022-yu-pod',          date:'2022-06-10', cat:'podcast',      title:'【Podcast】《余光中的愛與希望》' },
    { id:'2022-fanwocun',        date:'2022-02-25', cat:'literature',   title:'余師母-范我存參訪「余光中的愛與希望」', image:true },
    { id:'2022-chenxinghui',     date:'2022-02-20', cat:'literature',   title:'余光中的愛與希望線上開講 陳幸蕙老師與談' },
    { id:'2022-yu-online',       date:'2022-02-09', cat:'literature',   title:'【線上講座資訊】余光中的愛與希望', image:true },
    { id:'2018-bethlehem-open',  date:'2018-03-08', cat:'true-love',    title:'【敬邀】伯利恆早療暨融合教育中心落成典禮', isPinned:true,  pinOrder:3, image:true },
    { id:'2017-bethlehem-scene', date:'2017-10-25', cat:'true-love',    title:'「伯利恆早療暨融合教育中心」現場實景！', image:true },
    { id:'2017-rotary',          date:'2017-10-18', cat:'charity',      title:'一同走在愛與希望的路上—中央扶輪社', image:true },
    { id:'2017-luwei-car',       date:'2017-08-27', cat:'charity',      title:'真愛零距離 薛伯輝基金會贈車蘆葦啟智中心', image:true },
    { id:'2017-gan-id',          date:'2017-01-06', cat:'true-love',    title:'台灣有你揪甘心 林全院長頒發甘神父身分證', image:true },
    { id:'2016-bethlehem-beam',  date:'2016-10-17', cat:'true-love',    title:'永恆的印記—伯利恆早療暨融合教育中心上樑', image:true },
    { id:'2015-dimuer-award',    date:'2015-12-22', cat:'charity',      title:'地磨兒國小屏東縣鄉土歌謠比賽特優', image:true },
    { id:'2015-bethlehem-start', date:'2015-07-07', cat:'true-love',    title:'「伯利恆早療暨融合教育中心」歡喜開工！', image:true },
    { id:'2014-tainan-donate',   date:'2014-12-30', cat:'true-love',    title:'台南市長賴清德帶領慨捐甘惠忠神父 2,100 萬', image:true },
    { id:'2014-bethlehem-arch',  date:'2014-11-03', cat:'true-love',    title:'「伯利恆早療暨融合教育中心」建築發表會', image:true },
    { id:'2014-li',              date:'2014-07-30', cat:'lecture',      title:'【演講資訊】李家同《大量閱讀的重要性》', image:true },
    { id:'2014-hong',            date:'2014-05-17', cat:'lecture',      title:'【演講資訊】洪蘭《大腦與學習》' },
  ];

  let ACTIVE_YEAR = 'all';
  const LIST_PAGE_SIZE = 8;
  let LIST_SHOWN = LIST_PAGE_SIZE;

  function pinnedItems(){
    return NEWS_ITEMS.filter(it => it.isPinned).sort((a,b) => (a.pinOrder||0) - (b.pinOrder||0));
  }
  function regularItems(){
    const base = NEWS_ITEMS.filter(it => !it.isPinned);
    if (ACTIVE_YEAR === 'all') return base;
    return base.filter(it => it.date.startsWith(ACTIVE_YEAR));
  }
  function formatDate(iso){
    const [y,m,d] = iso.split('-');
    return `${y}.${m}.${d}`;
  }

  function rowHtml(it){
    const cat = CATEGORY_LABELS[it.cat] || it.cat;
    const date = formatDate(it.date);
    const hasImage = it.image ? '1' : '0';
    return `
      <a class="news-row" href="news.html#${it.id}" data-cat="${it.cat}" data-has-image="${hasImage}" data-cat-label="${cat}">
        <figure class="news-image"><span class="img-fill"></span></figure>
        <div class="news-body">
          <div class="meta">
            <span class="cat">${cat}</span>
            <span class="sep">·</span>
            <span class="date">${date}</span>
          </div>
          <h3 class="title">${it.title}</h3>
          <span class="article-action">繼續閱讀 →</span>
        </div>
      </a>
    `;
  }

  function render(){
    document.querySelectorAll('#yearNav .item').forEach(a => a.classList.toggle('on', a.dataset.year === ACTIVE_YEAR));

    const pins = pinnedItems();
    const regs = regularItems();

    // 置頂區塊 — 永遠最上, 不被年份過濾
    const pinnedBlock = document.getElementById('pinnedBlock');
    const pinnedList  = document.getElementById('pinnedList');
    const pinnedCount = document.getElementById('pinnedCount');
    if (pins.length === 0){
      pinnedBlock.hidden = true;
    } else {
      pinnedBlock.hidden = false;
      pinnedCount.textContent = `${pins.length} items`;
      pinnedList.innerHTML = pins.map(rowHtml).join('');
    }

    // 一般列表
    const newsList     = document.getElementById('newsList');
    const listTitle    = document.getElementById('listTitle');
    const listCount    = document.getElementById('listCount');
    const emptyState   = document.getElementById('emptyState');
    const loadMoreWrap = document.getElementById('loadMoreWrap');

    listTitle.textContent = ACTIVE_YEAR === 'all' ? '全部消息' : `${ACTIVE_YEAR} 年消息`;
    listCount.textContent = `${regs.length} items`;

    const shown = Math.min(LIST_SHOWN, regs.length);
    const sliced = regs.slice(0, shown);

    if (regs.length === 0){
      newsList.innerHTML = '';
      emptyState.hidden = false;
      loadMoreWrap.hidden = true;
    } else {
      emptyState.hidden = true;
      newsList.innerHTML = sliced.map(rowHtml).join('');
      loadMoreWrap.hidden = shown >= regs.length;
    }
  }

  /* ============ NAV / LOAD MORE ============ */
  document.querySelectorAll('#yearNav .item').forEach(a => {
    a.addEventListener('click', e => {
      e.preventDefault();
      ACTIVE_YEAR = a.dataset.year;
      LIST_SHOWN = LIST_PAGE_SIZE;
      render();
    });
  });
  document.getElementById('loadMoreBtn').addEventListener('click', () => {
    LIST_SHOWN += LIST_PAGE_SIZE;
    render();
  });

  

  render();
</script>
{% endblock %}
