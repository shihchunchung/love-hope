{% block scripts %}
<script>
// ===== 照片資料（依空間，含攝影師署名）=====
  const VENUE_PHOTOS = {
    hall: [
      {s:'images/venue/hall-02.jpg', c:'愛的講堂 ｜ 王采元 攝'},
      {s:'images/venue/hall-01.jpg', c:'愛的講堂 ｜ 張美滿 攝'},
      {s:'images/venue/hall-03.jpg', c:'愛的講堂 ｜ 王采元 攝'},
      {s:'images/venue/hall-04.jpg', c:'愛的講堂 ｜ 黃菱娸 攝'},
      {s:'images/venue/hall-05.jpg', c:'愛的講堂 ｜ 黃菱娸 攝'},
      {s:'images/venue/hall-06.jpg', c:'愛的講堂 ｜ 黃菱娸 攝'},
      {s:'images/venue/hall-07.jpg', c:'愛的講堂 ｜ 黃菱娸 攝'},
      {s:'images/venue/hall-08.jpg', c:'愛的講堂 ｜ 黃菱娸 攝'},
      {s:'images/venue/hall-09.jpg', c:'愛的講堂 ｜ 黃菱娸 攝'}
    ],
    huiru: [
      {s:'images/venue/huiru-01.jpg', c:'惠如美學教室 ｜ 王采元 攝'},
      {s:'images/venue/huiru-02.jpg', c:'惠如美學教室 ｜ 黃菱娸 攝'}
    ],
    food: [
      {s:'images/venue/food-02.jpg', c:'遇見輕食 ｜ 王采元 攝'},
      {s:'images/venue/food-01.jpg', c:'遇見輕食 ｜ 李佳陵 攝'},
      {s:'images/venue/food-03.jpg', c:'遇見輕食 ｜ 王采元 攝'},
      {s:'images/venue/food-04.jpg', c:'遇見輕食 ｜ 蔡宗昇 攝'}
    ]
  };

  // ===== 建立照片圖帶（marquee，重複一份以無縫循環）=====
  // 三組共用同一捲動速度（px/秒），duration 依各自軌道寬度換算 → 視覺速度一致
  const MARQUEE_SPEED = 70;
  function applyMarqueeSpeed(){
    document.querySelectorAll('.marquee-track').forEach(track => {
      const copyW = track.scrollWidth / 2;          // 內容重複兩份，取一份寬度
      if (copyW > 0) track.style.animationDuration = (copyW / MARQUEE_SPEED).toFixed(1) + 's';
    });
  }
  (function buildMarquees(){
    document.querySelectorAll('.marquee-wrap').forEach(wrap => {
      const key = wrap.dataset.space;
      const photos = VENUE_PHOTOS[key] || [];
      if (!photos.length) return;
      const track = document.createElement('div');
      track.className = 'marquee-track';
      track.style.animationDuration = '40s';        // 圖片載入前的暫定值
      const make = (p, i) => {
        const img = document.createElement('img');
        img.src = p.s; img.alt = p.c; img.loading = 'lazy';
        img.addEventListener('click', () => openLightbox(key, i));
        img.addEventListener('load', applyMarqueeSpeed);   // 載入後依實寬重算
        return img;
      };
      photos.forEach((p,i) => track.appendChild(make(p,i)));     // 第一份
      photos.forEach((p,i) => track.appendChild(make(p,i)));     // 第二份（循環用）
      wrap.appendChild(track);
    });
    window.addEventListener('load', applyMarqueeSpeed);
    window.addEventListener('resize', applyMarqueeSpeed);
  })();

  // ===== 燈箱 =====
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lbImg');
  const lbCap = document.getElementById('lbCap');
  let lbSet = [], lbIdx = 0;
  function openLightbox(key, idx){
    lbSet = VENUE_PHOTOS[key] || [];
    lbIdx = idx % lbSet.length;
    renderLightbox();
    lb.classList.add('on');
    document.body.style.overflow = 'hidden';
  }
  function renderLightbox(){
    const p = lbSet[lbIdx];
    if (!p) return;
    lbImg.src = p.s; lbImg.alt = p.c; lbCap.textContent = p.c;
  }
  function lbStep(d){ lbIdx = (lbIdx + d + lbSet.length) % lbSet.length; renderLightbox(); }
  function lbCloseFn(){ lb.classList.remove('on'); document.body.style.overflow = ''; }
  document.getElementById('lbClose').addEventListener('click', lbCloseFn);
  document.getElementById('lbPrev').addEventListener('click', () => lbStep(-1));
  document.getElementById('lbNext').addEventListener('click', () => lbStep(1));
  lb.addEventListener('click', e => { if (e.target === lb) lbCloseFn(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('on')) return;
    if (e.key === 'Escape') lbCloseFn();
    if (e.key === 'ArrowLeft') lbStep(-1);
    if (e.key === 'ArrowRight') lbStep(1);
  });

  // ===== SUB-NAV：平滑捲動 + scrollspy =====
  (function(){
    const items = Array.from(document.querySelectorAll('.sub-nav .item'));
    items.forEach(btn => btn.addEventListener('click', () => {
      const el = document.getElementById(btn.dataset.target);
      if (el) window.scrollTo({top: el.getBoundingClientRect().top + window.scrollY - 170, behavior:'smooth'});
    }));
    const sections = items.map(b => document.getElementById(b.dataset.target)).filter(Boolean);
    const spy = () => {
      const y = window.scrollY + 200;
      let cur = -1;
      sections.forEach((s,i) => { if (s.offsetTop <= y) cur = i; });
      items.forEach((b,i) => b.classList.toggle('on', i === cur));
    };
    let t = false;
    window.addEventListener('scroll', () => { if (t) return; t = true; requestAnimationFrame(() => { spy(); t = false; }); });
    spy();
  })();
</script>
{% endblock %}
