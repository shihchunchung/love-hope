---
permalink: venue.html
title: "場地租借｜薛伯輝基金會"
active: venue
---
{% extends "base.njk" %}

{% block styles %}
<style>
  /* ============ SUB-NAV（三空間錨點）============ */
  .sub-nav{background:#fff;position:sticky;top:140px;z-index:48;display:flex;justify-content:center;align-items:stretch;padding:var(--sp-3) var(--sp-6) 19px;border-bottom:1px solid var(--line-soft)}
  .sub-nav .item{padding:0 var(--sp-5);font-size:var(--t-meta);letter-spacing:1.5px;color:#666;font-weight:500;position:relative;line-height:1.75;cursor:pointer;transition:color .18s;background:none}
  .sub-nav .item:hover{color:var(--brand)}
  .sub-nav .item.on{color:var(--brand);font-weight:700}
  .sub-nav .item.on::after{content:"";position:absolute;left:50%;transform:translateX(-50%);bottom:-6px;width:24px;height:2px;background:var(--brand)}

  /* ============ HERO（全幅實拍）============ */
  .venue-hero{position:relative;height:clamp(440px,64vh,640px);overflow:hidden;background:#0f0f0f}
  .venue-hero>img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 58%}
  .venue-hero::after{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 72% 78% at 50% 50%,rgba(12,4,4,.32) 0%,rgba(12,4,4,.12) 100%)}
  .venue-hero .hero-inner{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center}
  .venue-hero .eyebrow{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:5px;text-transform:uppercase;color:rgba(255,255,255,.85);font-weight:600;margin-bottom:var(--sp-4);display:flex;align-items:center;gap:var(--sp-4)}
  .venue-hero .eyebrow::before{content:"";width:36px;height:1px;background:rgba(255,255,255,.7)}
  .venue-hero h1{font-size:var(--t-hero);color:#fff;letter-spacing:6px;line-height:1.1;font-weight:700;margin:0;text-indent:6px}
  .venue-hero .lead{font-size:var(--t-title-l);color:rgba(255,255,255,.94);letter-spacing:1.5px;font-weight:300;max-width:640px;line-height:1.85;text-wrap:pretty}
  .venue-hero .hero-attr{margin-top:var(--sp-4);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-body-s);letter-spacing:2.5px;color:rgba(255,255,255,.8);font-weight:400}

  /* ============ INTRO ============ */
  .venue-intro{padding:var(--sp-9) 0 var(--sp-7);background:#fff;text-align:center}
  .venue-intro p{font-size:var(--t-body-l);color:var(--body);line-height:1.95;max-width:720px;margin:0 auto;letter-spacing:.5px;text-wrap:pretty}
  .venue-intro .count{font-family:"IBM Plex Serif",sans-serif;color:var(--brand);font-weight:600}

  /* ============ SPACE SECTION（核心版型）============ */
  .space-sec{padding:var(--sp-10) 0;border-top:1px solid var(--line-soft)}
  .space-sec:first-of-type{border-top:none;padding-top:var(--sp-7)}
  .space-row{display:grid;grid-template-columns:minmax(260px,0.62fr) minmax(0,1.38fr);gap:var(--sp-8);align-items:start}
  .space-text .space-eyebrow{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:4px;text-transform:uppercase;color:var(--brand);font-weight:600;margin-bottom:var(--sp-3);display:block}
  .space-text .slogan{font-size:var(--t-title-l);color:var(--ink);letter-spacing:1.5px;font-weight:700;line-height:1.4;margin-bottom:var(--sp-3)}
  .space-text h2{font-size:var(--t-section);color:var(--ink);letter-spacing:2px;line-height:1.2;margin-bottom:var(--sp-3);font-weight:700}
  .space-text .space-meta{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:1px;color:var(--brand-dark);font-weight:500;margin-bottom:var(--sp-5)}
  .space-chips{display:flex;flex-wrap:wrap;gap:var(--sp-2) var(--sp-3);margin-bottom:var(--sp-5)}
  .space-chips .chip{font-size:var(--t-meta);letter-spacing:1px;color:var(--brand-dark);background:var(--brand-tint);padding:var(--sp-1) var(--sp-3);font-weight:600;border-radius:2px}
  .space-desc{font-size:var(--t-body);color:var(--body);line-height:1.9;margin-bottom:var(--sp-6);letter-spacing:.3px;text-wrap:pretty;max-width:440px}
  .space-block{margin-bottom:var(--sp-5)}
  .space-block .blk-label{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:var(--sp-3);display:flex;align-items:center;gap:var(--sp-3)}
  .space-block .blk-label::before{content:"";width:18px;height:1px;background:var(--muted)}
  .tag-row{display:flex;flex-wrap:wrap;gap:var(--sp-2)}
  .tag-row li{font-size:var(--t-meta);color:var(--body);border:1px solid var(--line);padding:3px var(--sp-3);letter-spacing:.5px;border-radius:2px}
  .equip-row{display:flex;flex-wrap:wrap;gap:var(--sp-1) var(--sp-4);font-size:var(--t-body-s);color:var(--body)}
  .equip-row li{position:relative;padding-left:var(--sp-4)}
  .equip-row li::before{content:"·";position:absolute;left:4px;color:var(--brand);font-weight:700}
  .more-link{display:inline-flex;align-items:center;gap:var(--sp-3);margin-top:var(--sp-2);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:2.5px;text-transform:uppercase;color:var(--ink);font-weight:600;transition:gap .2s,color .2s}
  .more-link svg{width:11px;height:auto}
  .more-link:hover{color:var(--brand);gap:var(--sp-4)}

  /* ============ MARQUEE（橫向照片帶 → 燈箱）============ */
  .marquee-col{display:flex;flex-direction:column}
  .marquee-wrap{position:relative;overflow:hidden;width:100%;height:clamp(300px,30vw,400px)}
  .marquee-track{position:absolute;top:0;left:0;height:100%;display:flex;width:max-content;animation:scrollx linear infinite}
  .marquee-track img{height:100%;width:auto;object-fit:cover;cursor:pointer;flex:none;margin-right:var(--sp-4);background:#1a0a0a;transition:filter .25s,transform .25s}
  .marquee-track img:hover{filter:brightness(1.06)}
  .marquee-wrap:hover .marquee-track{animation-play-state:paused}
  @keyframes scrollx{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  .marquee-hint{margin-top:var(--sp-3);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:1.5px;color:var(--muted);display:flex;align-items:center;gap:var(--sp-2)}
  @media (prefers-reduced-motion: reduce){.marquee-track{animation:none;flex-wrap:nowrap;overflow-x:auto}}

  /* ============ LIGHTBOX ============ */
  .lightbox{position:fixed;inset:0;background:rgba(10,4,4,.95);z-index:100;display:none;align-items:center;justify-content:center}
  .lightbox.on{display:flex}
  .lightbox figure{max-width:92vw;max-height:88vh;display:flex;flex-direction:column;align-items:center;gap:var(--sp-4)}
  .lightbox img{max-width:92vw;max-height:80vh;object-fit:contain;box-shadow:0 20px 60px rgba(0,0,0,.5)}
  .lightbox figcaption{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:1.5px;color:rgba(255,255,255,.72)}
  .lb-btn{position:absolute;width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,.12);color:#fff;display:flex;align-items:center;justify-content:center;font-size:26px;line-height:1;transition:background .2s;z-index:2}
  .lb-btn:hover{background:rgba(255,255,255,.25)}
  .lb-close{top:24px;right:24px;font-family:"IBM Plex Serif",sans-serif}
  .lb-prev{left:24px;top:50%;transform:translateY(-50%)}
  .lb-next{right:24px;top:50%;transform:translateY(-50%)}

  /* ============ BOOKING / 收費 ============ */
  .booking{padding:var(--sp-10) 0;background:var(--line-soft);border-top:1px solid var(--line-soft)}
  .section-head{display:flex;justify-content:space-between;align-items:flex-end;border-bottom:1px solid var(--ink);padding-bottom:var(--sp-6);margin-bottom:var(--sp-7)}
  .section-head .titles{display:flex;flex-direction:column;gap:var(--sp-3)}
  .section-head .subtitle{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:3.5px;color:var(--brand);font-weight:600;text-transform:uppercase;display:flex;align-items:center;gap:var(--sp-4)}
  .section-head .subtitle::before{content:"";width:24px;height:1px;background:var(--brand)}
  .section-head h2.section-title{font-size:var(--t-section);font-weight:700;color:var(--ink);letter-spacing:1.5px;line-height:1.25}
  .section-head .head-note{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);color:var(--muted);letter-spacing:1.5px}

  .process{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--sp-5);margin-bottom:var(--sp-9)}
  .step{position:relative;padding-top:var(--sp-6)}
  .step::before{content:attr(data-n);position:absolute;top:0;left:0;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-title-l);font-weight:600;color:var(--brand)}
  .step::after{content:"";position:absolute;top:13px;left:38px;right:0;height:1px;background:var(--line)}
  .step:last-child::after{display:none}
  .step h4{font-size:var(--t-title-s);color:var(--ink);letter-spacing:1px;margin-bottom:var(--sp-2);font-weight:700}
  .step p{font-size:var(--t-body-s);color:var(--body);line-height:1.75}

  .price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--sp-5);margin-bottom:var(--sp-6)}
  .price-card{background:#fff;border:1px solid var(--line);padding:var(--sp-6)}
  .price-card h4{font-size:var(--t-title-s);color:var(--ink);letter-spacing:1.5px;margin-bottom:var(--sp-4);font-weight:700;display:flex;align-items:baseline;gap:var(--sp-3)}
  .price-card h4 .cap{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);color:var(--muted);font-weight:500;letter-spacing:1px}
  .price-rows{display:flex;flex-direction:column;gap:var(--sp-3)}
  .price-rows .pr{display:flex;justify-content:space-between;align-items:baseline;font-size:var(--t-body-s);padding-bottom:var(--sp-3);border-bottom:1px dashed var(--line)}
  .price-rows .pr:last-child{border-bottom:none;padding-bottom:0}
  .price-rows .pr .k{color:var(--muted);letter-spacing:.5px}
  .price-rows .pr .v{font-family:"IBM Plex Serif",sans-serif;font-weight:600;color:var(--ink);letter-spacing:.5px}
  .price-rows .pr .v b{color:var(--brand-dark)}
  .pc-equip{margin-top:var(--sp-4);padding-top:var(--sp-4);border-top:1px solid var(--line);font-size:var(--t-caption);line-height:1.7;color:var(--muted);letter-spacing:.3px}
  .pc-equip b{font-family:"IBM Plex Serif",sans-serif;color:var(--body);font-weight:600;letter-spacing:1px;margin-right:var(--sp-2)}

  .booking-foot{display:flex;justify-content:space-between;align-items:center;gap:var(--sp-6);flex-wrap:wrap;padding-top:var(--sp-6);border-top:1px solid var(--line)}
  .notice-list{display:flex;flex-wrap:wrap;gap:var(--sp-2) var(--sp-5);font-size:var(--t-body-s);color:var(--body);max-width:780px}
  .notice-list li{position:relative;padding-left:var(--sp-4)}
  .notice-list li::before{content:"·";position:absolute;left:4px;color:var(--brand);font-weight:700}
  .price-caveat{font-size:var(--t-caption);color:var(--muted);letter-spacing:.5px;margin-top:var(--sp-4)}
  .pdf-btn{display:inline-flex;align-items:center;gap:var(--sp-3);padding:var(--sp-4) var(--sp-6);border:1px solid var(--ink);color:var(--ink);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:2px;text-transform:uppercase;font-weight:600;transition:all .2s;white-space:nowrap}
  .pdf-btn::after{content:"↓"}
  .pdf-btn:hover{background:var(--ink);color:#fff}

  /* ============ 申請洽詢表單 ============ */
  .enquiry{padding:var(--sp-10) 0;background:#fff}
  .enquiry-grid{display:grid;grid-template-columns:1.25fr .85fr;gap:var(--sp-9)}
  .enq-form{display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-5)}
  .field{display:flex;flex-direction:column;gap:var(--sp-2)}
  .field.full{grid-column:1/-1}
  .field label{font-size:var(--t-meta);letter-spacing:1px;color:var(--ink);font-weight:600}
  .field label .req{color:var(--brand);margin-left:2px}
  .field input,.field select,.field textarea{font-family:inherit;font-size:var(--t-body-s);color:var(--ink);border:1px solid var(--line);background:#fff;padding:var(--sp-3) var(--sp-4);transition:border-color .2s;border-radius:2px}
  .field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--brand)}
  .field textarea{resize:vertical;min-height:96px;line-height:1.7}
  .submit-btn{grid-column:1/-1;justify-self:start;display:inline-flex;align-items:center;gap:var(--sp-3);padding:var(--sp-4) var(--sp-8);background:var(--brand);color:#fff;font-size:var(--t-body-s);letter-spacing:3px;font-weight:500;transition:background .2s;margin-top:var(--sp-2)}
  .submit-btn::after{content:"→";font-family:"IBM Plex Serif",sans-serif}
  .submit-btn:hover{background:var(--brand-dark)}
  .enq-note{grid-column:1/-1;font-size:var(--t-caption);color:var(--muted);letter-spacing:.5px}
  .enq-aside{border-left:1px solid var(--line);padding-left:var(--sp-8);display:flex;flex-direction:column;gap:var(--sp-6)}
  .enq-aside .blk-label{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:var(--sp-2)}
  .enq-aside .tel{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-display);color:var(--brand);font-weight:600;letter-spacing:1px;line-height:1.1}
  .enq-aside p{font-size:var(--t-body-s);color:var(--body);line-height:1.8}

  /* ============ 交通與位置 ============ */
  .transit{padding:var(--sp-10) 0;background:var(--line-soft);border-top:1px solid var(--line-soft)}
  .transit-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:var(--sp-8);align-items:stretch}
  .map-embed{min-height:380px;background:#e6e1da;overflow:hidden;border:1px solid var(--line)}
  .map-embed iframe{width:100%;height:100%;min-height:380px;border:0;display:block;filter:grayscale(.25)}
  .transit-info{display:flex;flex-direction:column;gap:var(--sp-5)}
  .ti-block .ti-label{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;text-transform:uppercase;color:var(--brand);font-weight:700;margin-bottom:var(--sp-2);display:flex;align-items:center;gap:var(--sp-3)}
  .ti-block .ti-label::before{content:"";width:16px;height:1px;background:var(--brand)}
  .ti-block p{font-size:var(--t-body-s);color:var(--body);line-height:1.8}
  .ti-block p b{color:var(--ink);font-weight:700}
  .ti-block + .ti-block{padding-top:var(--sp-5);border-top:1px solid var(--line)}

  .drawer-nav a.is-external:hover .ext-mark{transform:translate(2px,-2px);opacity:1}

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1100px){
    .sub-nav{position:static}
    .venue-hero h1{letter-spacing:3px}
    .space-row{grid-template-columns:1fr;gap:var(--sp-6)}
    .marquee-col{order:-1}
    .marquee-wrap{flex:none;height:clamp(260px,44vw,380px);min-height:0}
    .space-desc{max-width:none}
    .process{grid-template-columns:repeat(2,1fr);gap:var(--sp-6)}
    .step::after{display:none}
    .price-grid{grid-template-columns:1fr}
    .enquiry-grid,.transit-grid{grid-template-columns:1fr;gap:var(--sp-7)}
    .enq-aside{border-left:none;border-top:1px solid var(--line);padding-left:0;padding-top:var(--sp-6)}
    .donate-card{grid-template-columns:1fr;gap:var(--sp-7);padding:var(--sp-7)}
    .donate-stats{border-left:none;border-top:1px solid rgba(255,255,255,.2);padding-left:0;padding-top:var(--sp-6)}
  }
  @media (max-width: 720px){
    .sub-nav{display:none}

    .wrap{padding:0 var(--sp-4)}
    .venue-hero{height:clamp(360px,56vh,460px)}
    .venue-hero h1{font-size:var(--t-display-l);letter-spacing:2px}
    .venue-hero .lead{font-size:var(--t-title-s)}
    .space-sec{padding:var(--sp-8) 0}
    .enq-form{grid-template-columns:1fr}
    .marquee-wrap{height:230px}
    .booking-foot{flex-direction:column;align-items:flex-start;gap:var(--sp-5)}
    .donate-band{padding:var(--sp-7) var(--sp-4)}
    .section-head{flex-direction:column;align-items:flex-start;gap:var(--sp-4)}
  }
</style>
{% endblock %}

{% block content %}
<!-- ===== SUB-NAV（三空間錨點）===== -->
<nav class="sub-nav" aria-label="場地分類">
  <button class="item" data-target="hall">愛的講堂</button>
  <button class="item" data-target="huiru">惠如美學教室</button>
  <button class="item" data-target="food">遇見輕食</button>
</nav>

<!-- ===== HERO ===== -->
<section class="venue-hero">
  <img src="images/venue/hall-02.jpg" alt="愛的講堂" fetchpriority="high">
  <div class="hero-inner">
    <div class="wrap">
      <h1>場地租借</h1>
    </div>
  </div>
</section>

<!-- ===== SPACE 01 · 愛的講堂 ===== -->
<section class="space-sec" id="hall">
  <div class="wrap">
    <div class="space-row">
      <div class="space-text">
        <p class="slogan">談教養，凡事皆教養。</p>
        <h2>愛的講堂</h2>
        <p class="space-meta">約 35 坪 · 可容納 100–120 人</p>
        <p class="space-desc">可舉辦演講、座談會、研習、教學、小型音樂會、小型舞蹈發表會、藝文展覽、美學教育等活動。</p>
        <a class="more-link" href="薛伯輝基金會場地使用辦法.pdf" target="_blank" rel="noopener">查看設備與收費<svg viewBox="0 0 12.65 23.89" fill="none" stroke="currentColor" stroke-width="2"><polyline points="0.35 23.53 11.95 11.95 0.35 0.35"/></svg></a>
      </div>
      <div class="marquee-col">
        <div class="marquee-wrap" data-space="hall"></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== SPACE 02 · 惠如美學教室 ===== -->
<section class="space-sec" id="huiru">
  <div class="wrap">
    <div class="space-row">
      <div class="space-text">
        <p class="slogan">談美學，生活即美學。</p>
        <h2>惠如美學教室</h2>
        <p class="space-meta">約 8 坪 · 可容納 10–20 人</p>
        <p class="space-desc">凝聚更多共識，可舉辦小型的會議、座談與美學教育等活動。</p>
        <a class="more-link" href="薛伯輝基金會場地使用辦法.pdf" target="_blank" rel="noopener">查看設備與收費<svg viewBox="0 0 12.65 23.89" fill="none" stroke="currentColor" stroke-width="2"><polyline points="0.35 23.53 11.95 11.95 0.35 0.35"/></svg></a>
      </div>
      <div class="marquee-col">
        <div class="marquee-wrap" data-space="huiru"></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== SPACE 03 · 遇見輕食 ===== -->
<section class="space-sec" id="food">
  <div class="wrap">
    <div class="space-row">
      <div class="space-text">
        <p class="slogan">輕食，是一種簡單哲學。</p>
        <h2>遇見輕食</h2>
        <p class="space-meta">白色家用廚房 · 可容納 10–30 人</p>
        <p class="space-desc">用清爽無負擔的食材分享健康，可舉辦小型烹飪教學、社團活動與家庭溫馨聚會等。</p>
        <a class="more-link" href="薛伯輝基金會場地使用辦法.pdf" target="_blank" rel="noopener">查看設備與收費<svg viewBox="0 0 12.65 23.89" fill="none" stroke="currentColor" stroke-width="2"><polyline points="0.35 23.53 11.95 11.95 0.35 0.35"/></svg></a>
      </div>
      <div class="marquee-col">
        <div class="marquee-wrap" data-space="food"></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== DONATE BAND ===== -->
<section class="donate-band">
  <div class="wrap">
    <div class="donate-card">
      <div class="donate-text">
        <div class="label">Donate</div>
        <h2>捐款支持<br>愛與希望的延續</h2>
        <p>每一份支持，都將化為文化教育、特殊教育與公益行動的力量。基金會持續公開捐款徵信，讓愛與希望被妥善託付。</p>
        <div class="actions">
          <a class="btn-w" href="donate.html">捐款方式</a>
          <a class="btn-wo" href="donate.html">捐款徵信</a>
        </div>
      </div>
