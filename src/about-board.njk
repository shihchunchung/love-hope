---
permalink: about-board.html
title: "董事會成員｜關於我們 — 薛伯輝基金會"
active: about
---
{% extends "base.njk" %}

{% block styles %}
<style>
  /* ============ SUB-NAV（關於我們 cluster・跨頁，比照真愛多多）============ */
  .sub-nav{background:#fff;position:sticky;top:140px;z-index:48;display:flex;justify-content:center;align-items:stretch;padding:var(--sp-3) var(--sp-6);flex-wrap:wrap;border-bottom:1px solid var(--line);font-family:"IBM Plex Serif",sans-serif}
  .sub-nav .item{padding:var(--sp-3) var(--sp-5);font-size:var(--t-body-s);letter-spacing:2px;color:#666;font-weight:500;position:relative;cursor:pointer;transition:color .18s;background:none;border:0;font-family:inherit;text-decoration:none}
  .sub-nav .item:hover{color:var(--brand)}
  .sub-nav .item.todo{color:#BBB;cursor:default}
  .sub-nav .item.todo:hover{color:#BBB}
  .sub-nav .item.on{color:var(--brand);font-weight:700}
  .sub-nav .item.on::after{content:"";position:absolute;left:50%;transform:translateX(-50%);bottom:-1px;width:24px;height:2px;background:var(--brand)}

  /* ============ TITLE BAND（純標題，無 hero 照片）============ */
  .story-title{padding:var(--sp-8) 0 var(--sp-7);background:#fff;border-bottom:1px solid var(--line-soft)}
  .story-title .story-eyebrow{display:block;font-family:"IBM Plex Serif",serif;color:var(--brand);letter-spacing:4px;font-size:var(--t-body-s);margin-bottom:var(--sp-3)}
  .story-title .story-h1{font-size:var(--t-display-l);letter-spacing:1.5px;line-height:1.25;color:var(--ink);margin-bottom:0;font-weight:700;max-width:900px}
  .story-title .story-sub{margin-top:var(--sp-4);font-size:var(--t-body);color:#666;letter-spacing:1.5px}

  /* ============ BOARD ============ */
  .board{background:#fff;padding:var(--sp-8) 0 var(--sp-9)}

  /* 董事長 feature */
  .chair-feature{display:grid;grid-template-columns:minmax(0,300px) 1fr;gap:clamp(var(--sp-6),5vw,var(--sp-8));align-items:center;padding-bottom:var(--sp-8);border-bottom:1px solid var(--line-soft)}
  .chair-feature .ph{margin:0}
  .chair-feature .ph img{width:100%;aspect-ratio:4/5;object-fit:cover;object-position:center 20%;display:block;border-radius:4px}
  .chair-feature .role{display:block;font-family:"IBM Plex Serif",serif;color:var(--brand);letter-spacing:4px;font-size:var(--t-body-s);margin-bottom:var(--sp-2)}
  .chair-feature .name{font-size:var(--t-display);letter-spacing:3px;color:var(--ink);font-weight:700;line-height:1.2;margin-bottom:var(--sp-4)}
  .chair-feature .titles{list-style:none;padding:0;margin:0 0 var(--sp-5)}
  .chair-feature .titles li{font-size:var(--t-body-l);line-height:1.9;color:var(--body)}
  .chair-feature .more{display:inline-block;font-size:var(--t-body-s);letter-spacing:1.5px;color:var(--brand);text-decoration:none;border-bottom:1px solid currentColor;padding-bottom:2px}
  .chair-feature .more:hover{color:var(--brand-dark)}

  /* 董事 group heading */
  .board-group-h{font-size:var(--t-title-s);color:var(--ink);font-weight:700;letter-spacing:2px;margin:var(--sp-8) 0 var(--sp-6);display:flex;align-items:center;gap:var(--sp-3)}
  .board-group-h::before{content:"";width:24px;height:1px;background:var(--brand);flex-shrink:0}

  /* 董事：卡片格（無照片者用中性淺灰色塊預留）*/
  .member-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:clamp(var(--sp-5),3vw,var(--sp-6))}
  .member .ph{margin:0}
  .member .ph img{width:100%;aspect-ratio:4/5;object-fit:cover;display:block;border-radius:4px}
  .member .ph-empty{width:100%;aspect-ratio:4/5;border-radius:4px;background:var(--line)}
  .member .m-role{display:block;font-family:"IBM Plex Serif",serif;color:var(--brand);letter-spacing:2px;font-size:var(--t-meta);margin:var(--sp-4) 0 var(--sp-1)}
  .member .m-name{font-size:var(--t-title-s);letter-spacing:2px;color:var(--ink);font-weight:700;margin-bottom:var(--sp-3)}
  .member .m-titles{list-style:none;padding:0;margin:0}
  .member .m-titles li{font-size:var(--t-body-s);line-height:1.7;color:var(--body)}

  /* ============ RWD ============ */
  @media (max-width: 1100px){
    .sub-nav{padding:var(--sp-3) var(--sp-4);position:static}
    .sub-nav .item{padding:var(--sp-3) var(--sp-4);letter-spacing:1.5px}
    .sub-nav .item.on::after{width:20px}
    .story-title{padding:var(--sp-7) 0 var(--sp-6)}
    .board{padding:var(--sp-7) 0 var(--sp-9)}
    .member-grid{grid-template-columns:repeat(2,1fr);gap:var(--sp-6) var(--sp-5)}
    .donate-card{grid-template-columns:1fr;gap:var(--sp-7);padding:var(--sp-7);border-radius:4px}
    .donate-text{padding:0}
    .donate-stats{border-left:none;border-top:1px solid rgba(255,255,255,.2);padding-left:0;padding-top:var(--sp-6)}
  }
  @media (max-width: 720px){
    .sub-nav{padding:var(--sp-2) var(--sp-3)}
    .sub-nav .item{padding:var(--sp-2) var(--sp-3);font-size:var(--t-meta);letter-spacing:1px}
    .wrap{padding:0 var(--sp-4)}
    .story-title{padding:var(--sp-7) 0 var(--sp-6)}
    .story-title .story-h1{font-size:var(--t-display);letter-spacing:1.5px}
    .board{padding:var(--sp-6) 0 var(--sp-8)}
    .chair-feature{grid-template-columns:1fr;gap:var(--sp-6)}
    .chair-feature .ph img{aspect-ratio:3/2;max-height:60vh;object-position:center 22%}
    .chair-feature .name{font-size:var(--t-title)}
    .member-grid{gap:var(--sp-6) var(--sp-5)}
    .donate-band{padding:var(--sp-7) var(--sp-4)}
    .donate-card{padding:var(--sp-6) var(--sp-5);gap:var(--sp-6)}
    .donate-stats{padding-top:var(--sp-5)}
  }
</style>
{% endblock %}

{% block content %}
<!-- ===== SUB-NAV（關於我們 3 子頁・跨頁）===== -->
<nav class="sub-nav" aria-label="關於我們子頁">
