---
{% extends "base.njk" %}

{% block styles %}
<style>
  /* ============ 捐款徵信頁（news 式：年度 sub-nav + 分區列表；內容靜態渲染，JS 只做年份過濾）============ */
  [hidden]{display:none !important}
  html{scroll-behavior:smooth}

  /* ---- 頁首（沿用 actions.njk 的 .page-hero）---- */
  .page-hero{padding:var(--sp-9) 0 var(--sp-7);background:#fff;border-bottom:1px solid var(--ink)}
  .page-hero h1{font-size:var(--t-display-l);letter-spacing:1.5px;font-weight:700;color:var(--ink);line-height:1.25;margin-bottom:var(--sp-4)}
  .page-hero .lead{font-size:var(--t-title-s);color:var(--body);font-weight:500;line-height:1.85;max-width:640px;letter-spacing:0}
  .page-hero .closing{margin-top:var(--sp-5);font-size:var(--t-body-s);color:var(--muted);line-height:1.9;max-width:680px;text-wrap:pretty}

  /* ---- 年度 SUB-NAV（沿用 news.njk）---- */
  .sub-nav{background:#fff;position:sticky;top:140px;z-index:48;display:flex;justify-content:center;align-items:stretch;padding:var(--sp-3) var(--sp-6);flex-wrap:wrap;border-bottom:1px solid var(--line);font-family:"IBM Plex Serif",sans-serif}
  .sub-nav .item{padding:var(--sp-3) var(--sp-5);font-size:var(--t-body-s);letter-spacing:2px;color:#666;font-weight:500;position:relative;cursor:pointer;transition:color .18s;background:none;border:0;font-family:inherit;text-decoration:none}
  .sub-nav .item:hover{color:var(--brand)}
  .sub-nav .item.on{color:var(--brand);font-weight:700}
  .sub-nav .item.on::after{content:"";position:absolute;left:50%;transform:translateX(-50%);bottom:-1px;width:24px;height:2px;background:var(--brand)}

  /* ---- 列表區（沿用 news.njk 的 .list-section / .list-header）---- */
  .list-section{padding:var(--sp-8) 0 var(--sp-10);background:#fff}
  .year-block{margin-bottom:var(--sp-9)}
  .year-block:last-child{margin-bottom:0}
  .list-header{display:flex;align-items:baseline;justify-content:space-between;gap:var(--sp-4);border-bottom:1px solid var(--ink);padding-bottom:var(--sp-4);margin-bottom:var(--sp-6)}
  .list-header h2{font-size:var(--t-title);font-weight:700;letter-spacing:1.5px;color:var(--ink)}
  .list-header .count{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2.5px;color:var(--muted);font-weight:600}

  /* ---- 年內子組（年度徵信 / 真愛多多專案）---- */
  .rg{margin-bottom:var(--sp-6)}
  .rg:last-child{margin-bottom:0}
  .rg-title{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-meta);letter-spacing:2.5px;color:var(--brand);font-weight:600;padding-bottom:var(--sp-3);margin-bottom:var(--sp-3);border-bottom:1px solid var(--line)}

  /* ---- 報告清單（2 欄）---- */
  .rlist{display:grid;grid-template-columns:repeat(2,1fr);gap:0 var(--sp-7);list-style:none;margin:0;padding:0}
  .rlist li{margin:0}
  .rlist li.r-rep{grid-column:1 / -1}
  .rlist a{display:flex;align-items:baseline;gap:var(--sp-3);padding:var(--sp-3) 0;font-size:var(--t-body-s);color:var(--body);line-height:1.55;border-bottom:1px solid var(--line-soft);transition:color .2s,padding-left .2s;text-wrap:pretty}
  .rlist a::after{content:"↗";margin-left:auto;padding-left:var(--sp-4);color:var(--muted);font-weight:400;transition:color .2s}
  .rlist a:hover{color:var(--brand);padding-left:var(--sp-2)}
  .rlist a:hover::after{color:var(--brand)}
  .rlist li.r-rep a{font-weight:700;color:var(--ink)}
  .rlist li.r-rep a:hover{color:var(--brand)}

  /* ---- RESPONSIVE（沿用 news 斷點）---- */
  @media (max-width:1100px){
    .sub-nav{position:static;padding:var(--sp-3) var(--sp-4)}
    .sub-nav .item{padding:var(--sp-3) var(--sp-4);letter-spacing:1.5px}
    .sub-nav .item.on::after{width:20px}
  }
  @media (max-width:720px){
    .sub-nav{display:none}
    .wrap{padding:0 var(--sp-4)}
    .page-hero{padding:var(--sp-7) 0 var(--sp-6)}
    .page-hero .lead{font-size:var(--t-body);line-height:1.85}
    .list-section{padding:var(--sp-6) 0 var(--sp-8)}
    .rlist{grid-template-columns:1fr;gap:0}
  }
</style>
{% endblock %}

