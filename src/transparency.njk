<!-- ===== 頁首 ===== -->
<section class="page-hero">
  <div class="wrap">
    <h1>捐款徵信</h1>
    <p class="lead">薛伯輝基金會依《公益勸募條例》定期公開財務徵信，列出歷年捐款人名單、本會捐助單位、政府補助案明細表，以及「真愛多多！」勸募專案的收支報告與每月捐款人名單徵信。</p>
    <p class="closing">「真愛多多！」為興建「伯利恆早療暨融合教育中心」所發起的勸募專案，已於 2018 年執行完竣並結案，各年度收支報告與每月名單徵信列於下方對應年度。</p>
  </div>
</section>

<!-- ===== 年度 SUB-NAV ===== -->
<nav class="sub-nav" id="yearNav" aria-label="年度">
  <a class="item on" data-year="all" href="#all">全部</a>
  {%- for yr in years %}
  <a class="item" data-year="{{ yr.year }}" href="#y{{ yr.year }}">{{ yr.year }}</a>
  {%- endfor %}
</nav>

<!-- ===== 依年度分區列表（靜態渲染；JS 只切換顯示）===== -->
<section class="list-section">
  <div class="wrap">
    {%- for yr in years %}
    {%- set cnt = 0 -%}
    {%- if yr.annual %}{% set cnt = cnt + (yr.annual | length) %}{% endif -%}
    {%- if yr.project %}
      {%- set cnt = cnt + (yr.project.summary | length) -%}
      {%- if yr.project.extra %}{% set cnt = cnt + (yr.project.extra | length) %}{% endif -%}
      {%- if yr.project.monthsExplicit %}{% set cnt = cnt + (yr.project.monthsExplicit | length) %}{% else %}{% set cnt = cnt + (yr.project.months | length) %}{% endif -%}
    {%- endif -%}
    <div class="year-block" id="y{{ yr.year }}" data-year="{{ yr.year }}">
      <div class="list-header">
        <h2>{{ yr.year }}</h2>
        <span class="count">{{ cnt }} 份報告</span>
      </div>
      {%- if yr.annual %}
      <div class="rg">
        <div class="rg-title">年度徵信</div>
        <ul class="rlist">
          {%- for it in yr.annual %}
          <li><a href="pdfs/audit/{{ it.f | urlencode }}" target="_blank" rel="noopener">{{ it.l }}</a></li>
          {%- endfor %}
        </ul>
      </div>
      {%- endif %}
      {%- if yr.project %}
      <div class="rg">
        <div class="rg-title">真愛多多！興建伯利恆早療暨融合教育中心</div>
        <ul class="rlist">
          {%- for it in yr.project.summary %}
          <li class="r-rep"><a href="pdfs/audit/{{ it.f | urlencode }}" target="_blank" rel="noopener">{{ it.l }}</a></li>
          {%- endfor %}
          {%- if yr.project.extra %}{% for it in yr.project.extra %}
          <li class="r-rep"><a href="pdfs/audit/{{ it.f | urlencode }}" target="_blank" rel="noopener">{{ it.l }}</a></li>
          {%- endfor %}{% endif %}
          {%- if yr.project.monthsExplicit %}
            {%- for it in yr.project.monthsExplicit %}
          <li><a href="pdfs/audit/{{ it.f | urlencode }}" target="_blank" rel="noopener">{{ it.l }}</a></li>
            {%- endfor %}
          {%- else %}
            {%- for m in yr.project.months %}
          <li><a href="pdfs/audit/{{ (yr.project.yk + '年度' + m + '月' + projBase + '.pdf') | urlencode }}" target="_blank" rel="noopener">{{ m }} 月　捐款人名單徵信</a></li>
            {%- endfor %}
          {%- endif %}
        </ul>
      </div>
      {%- endif %}
    </div>
    {%- endfor %}
  </div>
</section>
{% endblock %}

{% block scripts %}
<script>
  // 年度過濾：點 sub-nav → 顯示該年度區塊（「全部」顯示全部）。內容是靜態 HTML，這裡只切換 hidden。
  const tabs = document.querySelectorAll('#yearNav .item');
  const blocks = document.querySelectorAll('.year-block');
  function setYear(y){
    tabs.forEach(t => t.classList.toggle('on', t.dataset.year === y));
    blocks.forEach(b => { b.hidden = !(y === 'all' || b.dataset.year === y); });
  }
  tabs.forEach(t => t.addEventListener('click', e => { e.preventDefault(); setYear(t.dataset.year); }));
  setYear('all');
</script>
{% endblock %}
