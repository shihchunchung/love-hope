---
permalink: transparency.html
title: "捐款徵信｜薛伯輝基金會"
active: transparency
---
{% extends "base.njk" %}

{% block styles %}
<style>
  /* ============ 捐款徵信頁（下拉查詢 + 結果表格；靜態渲染，JS 只做篩選。跨頁子選單已移進主導覽列「捐款徵信」下拉）============ */
  [hidden]{display:none !important}
  html{scroll-behavior:smooth}

  /* ---- 頁首（標題置中、品牌紅；內文左對齊置中欄）---- */
  .page-hero{padding:var(--sp-9) 0 var(--sp-6);background:#fff;text-align:center}
  .page-hero h1{font-size:var(--t-display-l);letter-spacing:2px;font-weight:700;color:var(--brand);line-height:1.25;margin-bottom:var(--sp-5)}
  .page-hero .lead{font-size:var(--t-body);color:var(--body);font-weight:500;line-height:1.95;max-width:760px;margin:0 auto;letter-spacing:0;text-align:left;text-wrap:pretty}
  .page-hero .hero-dl{color:var(--brand);font-weight:700;border-bottom:1px solid var(--brand);white-space:nowrap}
  .page-hero .hero-dl::after{content:"↓";margin-left:2px}
  .hero-contact{list-style:none;margin:var(--sp-5) auto 0;padding:0;max-width:760px;display:flex;flex-wrap:wrap;gap:var(--sp-3) var(--sp-6);text-align:left;font-size:var(--t-body-s)}
  .hero-contact li{display:flex;align-items:center;gap:var(--sp-3);color:var(--body)}
  .hero-contact .k{font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2px;color:var(--brand);font-weight:600}
  .hero-contact a{color:var(--body);text-decoration:none;transition:color .18s}
  .hero-contact a:hover{color:var(--brand)}
  .hero-notes{max-width:760px;margin:var(--sp-5) auto 0;text-align:left;padding-top:var(--sp-5);border-top:1px solid var(--line)}
  .hero-notes p{font-size:var(--t-body-s);color:var(--muted);line-height:1.85;text-wrap:pretty}
  .hero-notes p+p{margin-top:var(--sp-3)}

  /* ---- 徵信查詢區 ---- */
  .query-section{padding:var(--sp-8) 0 var(--sp-10);background:#fff}
  .query-section h2{font-size:var(--t-title);font-weight:700;letter-spacing:1.5px;color:var(--ink);margin-bottom:var(--sp-5)}
  .query-bar{display:flex;flex-wrap:wrap;gap:var(--sp-4);align-items:flex-end;padding-bottom:var(--sp-5);border-bottom:1px solid var(--ink);margin-bottom:var(--sp-5)}
  .query-field{display:flex;flex-direction:column;gap:var(--sp-2)}
  .query-field label{font-size:var(--t-caption);letter-spacing:2px;color:var(--muted);font-weight:600;font-family:"IBM Plex Serif",sans-serif}
  .query-field select{font-size:var(--t-body-s);padding:var(--sp-3) var(--sp-4);border:1px solid var(--line);border-radius:4px;background:#fff;color:var(--ink);min-width:220px;font-family:inherit;cursor:pointer}
  .query-field select:focus{outline:2px solid var(--brand);border-color:var(--brand)}
  .query-btn{padding:var(--sp-3) var(--sp-7);background:var(--brand);color:#fff;border:0;border-radius:4px;font-size:var(--t-body-s);letter-spacing:2px;font-weight:600;cursor:pointer;transition:background .18s;font-family:inherit}
  .query-btn:hover{background:var(--brand-dark)}

  /* ---- 結果表格（單欄「徵信報告」；點擊另開視窗 PDF；按「查詢」前整塊隱藏）---- */
  .result-table{width:100%;border-collapse:collapse}
  .result-table th{text-align:left;font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:2px;color:var(--brand);font-weight:600;padding:var(--sp-3) var(--sp-4);border-bottom:2px solid var(--brand)}
  .result-table td{padding:var(--sp-3) var(--sp-4);border-bottom:1px solid var(--line-soft);vertical-align:baseline}
  .result-table tr:hover td{background:var(--brand-tint)}
  .r-name a{color:var(--body);font-size:var(--t-body-s);line-height:1.55;text-decoration:none;transition:color .18s}
  .r-name a::after{content:"↗";margin-left:var(--sp-2);color:var(--muted);font-weight:400}
  .r-name a:hover{color:var(--brand)}
  .r-name a:hover::after{color:var(--brand)}
  .r-yr{display:inline-block;margin-left:var(--sp-3);font-family:"IBM Plex Serif",sans-serif;font-size:var(--t-caption);letter-spacing:1px;color:var(--muted)}
  .q-empty{padding:var(--sp-7) 0;text-align:center;color:var(--muted);font-size:var(--t-body-s)}

  /* ---- SUB-NAV (捐款徵信跨頁 tabs；視覺同 news/venue/actions) ---- */
  .sub-nav{background:#fff;position:sticky;top:140px;z-index:48;display:flex;justify-content:center;align-items:stretch;padding:var(--sp-3) var(--sp-6);flex-wrap:wrap;border-bottom:1px solid var(--line);font-family:"IBM Plex Serif",sans-serif}
  .sub-nav .item{padding:var(--sp-3) var(--sp-5);font-size:var(--t-body-s);letter-spacing:2px;color:#666;font-weight:500;position:relative;cursor:pointer;transition:color .18s;background:none;border:0;font-family:inherit;text-decoration:none}
  .sub-nav .item:hover{color:var(--brand)}
  .sub-nav .item.on{color:var(--brand);font-weight:700}
  .sub-nav .item.on::after{content:"";position:absolute;left:50%;transform:translateX(-50%);bottom:-1px;width:24px;height:2px;background:var(--brand)}

  /* ---- RESPONSIVE ---- */
  @media (max-width:1100px){
    .sub-nav{padding:var(--sp-3) var(--sp-4);position:static}
    .sub-nav .item{padding:var(--sp-3) var(--sp-4);letter-spacing:1.5px}
    .sub-nav .item.on::after{width:20px}
  }
  @media (max-width:720px){
    .sub-nav{display:none}
    .wrap{padding:0 var(--sp-4)}
    .page-hero{padding:var(--sp-7) 0 var(--sp-5)}
    .page-hero .lead{font-size:var(--t-body);line-height:1.85}
    .query-field{flex:1 1 100%}
    .query-field select{min-width:0;width:100%}
    .query-btn{width:100%}
  }
</style>
{% endblock %}

