<!-- ===== 頁首（文案來源：捐款徵信主頁.pages）===== -->
<section class="page-hero">
  <div class="wrap">
    <h1>捐款徵信</h1>
    <p class="lead">依據「財團法人法」第 25 條規定，除捐贈者事先以書面表示反對外，本會須主動公開捐贈者之姓名及捐款金額。為因應相關法規規範，倘若您不希望公開捐款資訊，敬請下載 <a class="hero-dl" href="pdfs/公開資訊意願聲明書.pdf" target="_blank" rel="noopener">公開資訊意願聲明書</a>，填妥後以拍照、掃描、傳真等方式回傳至信箱；若您未主動回覆，將視為同意公開個人捐款資訊以利徵信。</p>
    <ul class="hero-contact">
      <li><span class="k">信箱</span><a href="mailto:love.hopech@gmail.com">love.hopech@gmail.com</a></li>
      <li><span class="k">電話</span><a href="tel:+886223816678">(02) 2381-6678</a></li>
      <li><span class="k">傳真</span>(02) 2381-3171</li>
    </ul>
    <div class="hero-notes">
      <p>※ 若您同時以數個名義捐款，須請填具個別聲明書。</p>
      <p>※ 捐款後因需人工入帳作業時間，需至次月才能上傳官網進行徵信；公開後之徵信紀錄若日後有變更捐款人抬頭、捐款金額異動等情事，系統無法自動更新徵信內容，請以「年度捐款收據」或「上傳國稅局資料」為主。</p>
    </div>
  </div>
</section>

<!-- ===== 徵信查詢 ===== -->
<section class="query-section">
  <div class="wrap">
    <h2>徵信查詢</h2>
    <div class="query-bar">
      <div class="query-field">
        <label for="qYear">年度</label>
        <select id="qYear">
          <option value="all">全部</option>
          {%- for yr in years %}
          <option value="{{ yr.year }}">{{ yr.year }}</option>
          {%- endfor %}
        </select>
      </div>
      <div class="query-field">
        <label for="qType">徵信報告</label>
        <select id="qType">
          <option value="all">全部</option>
          <option value="donor">捐款人名單</option>
          <option value="gov">政府補助案明細</option>
          <option value="unit">本會捐助單位名單</option>
          <option value="project">真愛多多系列</option>
        </select>
      </div>
      <button class="query-btn" id="qBtn" type="button">查詢</button>
    </div>

    <div id="results" hidden>
    <table class="result-table" id="resultTable">
      <thead>
        <tr><th class="col-name">徵信報告</th></tr>
      </thead>
      <tbody id="resultBody">
        {%- for yr in years %}
        {%- if yr.annual %}{% for it in yr.annual %}
        <tr data-year="{{ yr.year }}" data-type="{{ it.t }}">
          <td class="r-name"><a href="pdfs/audit/{{ it.f | urlencode }}" target="_blank" rel="noopener">{{ it.l }}</a><span class="r-yr">{{ yr.year }}</span></td>        </tr>
        {%- endfor %}{% endif %}
        {%- if yr.project %}
          {%- for it in yr.project.summary %}
        <tr data-year="{{ yr.year }}" data-type="project">
          <td class="r-name"><a href="pdfs/audit/{{ it.f | urlencode }}" target="_blank" rel="noopener">{{ it.l }}</a><span class="r-yr">{{ yr.year }}・真愛多多</span></td>        </tr>
          {%- endfor %}
          {%- if yr.project.extra %}{% for it in yr.project.extra %}
        <tr data-year="{{ yr.year }}" data-type="project">
          <td class="r-name"><a href="pdfs/audit/{{ it.f | urlencode }}" target="_blank" rel="noopener">{{ it.l }}</a><span class="r-yr">{{ yr.year }}・真愛多多</span></td>        </tr>
          {%- endfor %}{% endif %}
          {%- if yr.project.monthsExplicit %}
            {%- for it in yr.project.monthsExplicit %}
        <tr data-year="{{ yr.year }}" data-type="project">
          <td class="r-name"><a href="pdfs/audit/{{ it.f | urlencode }}" target="_blank" rel="noopener">{{ it.l }}</a><span class="r-yr">{{ yr.year }}・真愛多多</span></td>        </tr>
            {%- endfor %}
          {%- else %}
            {%- for m in yr.project.months %}
        <tr data-year="{{ yr.year }}" data-type="project">
          <td class="r-name"><a href="pdfs/audit/{{ (yr.project.yk + '年度' + m + '月' + projBase + '.pdf') | urlencode }}" target="_blank" rel="noopener">{{ m }} 月　捐款人名單徵信</a><span class="r-yr">{{ yr.year }}・真愛多多</span></td>
        </tr>
            {%- endfor %}
          {%- endif %}
        {%- endif %}
        {%- endfor %}
      </tbody>
    </table>
    <div class="q-empty" id="qEmpty" hidden>查無符合的徵信報告，請調整查詢條件。</div>
    </div>
  </div>
</section>
{% endblock %}

{% block scripts %}
<script>
  // 徵信查詢：按下「查詢」才篩選並顯示結果；未查詢前整塊隱藏。內容是靜態 HTML，這裡只切換 hidden（沿用本站靜態渲染慣例）。
  const yearSel = document.getElementById('qYear');
  const typeSel = document.getElementById('qType');
  const qBtn    = document.getElementById('qBtn');
  const rows    = Array.from(document.querySelectorAll('#resultBody tr'));
  const results = document.getElementById('results');
  const table   = document.getElementById('resultTable');
  const empty   = document.getElementById('qEmpty');
  function applyQuery(){
    const y = yearSel.value, t = typeSel.value;
    let shown = 0;
    rows.forEach(r => {
      const ok = (y === 'all' || r.dataset.year === y) && (t === 'all' || r.dataset.type === t);
      r.hidden = !ok;
      if (ok) shown++;
    });
    results.hidden = false;
    table.hidden = shown === 0;
    empty.hidden = shown > 0;
  }
  qBtn.addEventListener('click', applyQuery);
</script>
{% endblock %}
