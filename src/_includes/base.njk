<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<title>{{ title }}</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700;900&family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="tokens.css">
<link rel="stylesheet" href="app.css">
{% block styles %}{% endblock %}
</head>
<body>

{%- set navItems = [
  { href: "about.html",     label: "關於我們", key: "about" },
  { href: "people.html",    label: "慈善身影", key: "people" },
  { href: "actions.html",   label: "公益行動", key: "actions" },
  { href: "true-love.html", label: "真愛多多", key: "true-love" },
  { href: "news.html",      label: "最新消息", key: "news" },
  { href: "transparency.html", label: "捐款徵信", key: "donation",
    match: ["donation", "transparency", "donate", "donate-faq"] },
  { href: "shop.html",      label: "公益小舖", key: "shop" },
  { href: "https://www.facebook.com/LoveHopeYLC/", label: "搖籃咖啡", key: "cafe", external: true },
  { href: "venue.html",     label: "場地租借", key: "venue" }
] -%}

<!-- ===== HEADER ===== -->
<header class="app-header">
  <div class="row">
    <div class="left">
      <button class="nav-toggle" id="navToggle" type="button" aria-label="open menu">
        <span></span><span></span><span></span>
      </button>
      <div class="header-socials">
        <a aria-label="facebook" href="https://www.facebook.com/LoveHopeF" target="_blank" rel="noopener"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-9h3l.5-4H13V6.5c0-1.2.3-2 2-2H17V1c-.3 0-1.5-.2-2.8-.2C11.4.8 10 2.7 10 5.9V9H7v4h3v9h3z"/></svg></a>
        <a aria-label="instagram" href="#"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></a>
        <a aria-label="youtube" href="#"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21.6 7.2s-.2-1.4-.8-2c-.7-.8-1.6-.8-2-.9C15.9 4 12 4 12 4s-3.9 0-6.8.3c-.4.1-1.3.1-2 .9-.6.6-.8 2-.8 2S2 8.8 2 10.5v1.5c0 1.7.2 3.3.2 3.3s.2 1.4.8 2c.7.8 1.7.8 2.1.9 1.6.2 6.9.2 6.9.2s3.9 0 6.8-.3c.4-.1 1.3-.1 2-.9.6-.6.8-2 .8-2s.2-1.6.2-3.3v-1.5c0-1.7-.2-3.3-.2-3.3zM10 14V8l5 3-5 3z"/></svg></a>
        <a aria-label="line" href="#"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3C6.5 3 2 6.6 2 11c0 4 3.6 7.4 8.5 8 .3 0 .8.2.9.5.1.2.1.5 0 .8l-.1.6c-.1.2-.3.9.8.5 1.1-.5 5.8-3.4 7.9-5.8C21.5 14 22.5 12.6 22 11c0-4.4-4.5-8-10-8z"/></svg></a>
      </div>
    </div>
    <a class="logo" href="index.html"><img src="images/logo.png" alt="薛伯輝基金會 Love Hope Foundation"></a>
    <div class="right">
      <a class="donate-btn" href="donate.html">捐款支持</a>
      <div class="header-utility">
        <a href="#">EN</a>
        <a href="#">登入</a>
      </div>
    </div>
  </div>
</header>

<!-- ===== NAV ===== -->
<nav class="app-nav">
  <div class="row">
    {%- for item in navItems %}
    {%- if item.external %}
    <a href="{{ item.href }}" class="is-external" target="_blank" rel="noopener">{{ item.label }} <span class="ext-mark">↗</span></a>
    {%- else %}
    <a href="{{ item.href }}"{% if active == item.key or (item.match and active in item.match) %} class="active"{% endif %}>{{ item.label }}</a>
    {%- endif %}
    {%- endfor %}
  </div>
</nav>

{% block content %}{% endblock %}

<!-- ===== FOOTER (La Vie minimal + 法人聯絡資訊) ===== -->
<footer class="app-footer">
  <div class="footer-info">
    <p class="footer-address">10043 台北市中正區博愛路 154 號 6 樓</p>
    <p class="footer-contact">
      <span><span class="lbl">電話</span>(02) 2381-6678</span>
      <span class="dot">·</span>
      <span><span class="lbl">傳真</span>(02) 2381-3171</span>
      <span class="dot">·</span>
      <a href="mailto:love.hopech@gmail.com">love.hopech@gmail.com</a>
    </p>
    <div class="footer-giro">
      <span class="giro-label">郵政劃撥</span>
      <span class="giro-cell">帳號<b>50067771</b></span>
      <span class="giro-sep">｜</span>
      <span class="giro-cell">戶名<b>財團法人薛伯輝基金會</b></span>
    </div>
  </div>
  <ul class="footer-links">
    <li><a href="about.html">關於我們</a></li>
    <li><a href="people.html">慈善身影</a></li>
    <li><a href="actions.html">公益行動</a></li>
    <li><a href="true-love.html">真愛多多</a></li>
    <li><a href="news.html">最新消息</a></li>
    <li><a href="shop.html">公益小舖</a></li>
    <li><a href="https://www.facebook.com/LoveHopeYLC/" class="is-external" target="_blank" rel="noopener">搖籃咖啡 <span class="ext-mark">↗</span></a></li>
    <li><a href="venue.html">場地租借</a></li>
    <li><a href="transparency.html">捐款徵信</a></li>
    <li><a href="mailto:love.hopech@gmail.com">聯絡我們</a></li>
    <li><a href="privacy.html">隱私權政策</a></li>
  </ul>
  <p class="footer-copy">© 2026 財團法人薛伯輝基金會　版權所有</p>
</footer>

<!-- ===== MOBILE DRAWER ===== -->
<div class="drawer-backdrop" id="drawerBackdrop"></div>
<aside class="drawer" id="drawer" aria-hidden="true">
  <div class="drawer-head">
    <button class="drawer-close" id="drawerClose" type="button" aria-label="close menu">×</button>
    <div class="drawer-utility">
      <a href="#">EN</a>
      <span class="sep">/</span>
      <a href="#">登入</a>
    </div>
  </div>
  <nav class="drawer-nav">
    {%- for item in navItems %}
    {%- if item.external %}
    <a href="{{ item.href }}" class="is-external" target="_blank" rel="noopener">{{ item.label }} <span class="ext-mark">↗</span></a>
    {%- else %}
    <a href="{{ item.href }}"{% if active == item.key or (item.match and active in item.match) %} class="active"{% endif %}>{{ item.label }}</a>
    {%- endif %}
    {%- endfor %}
  </nav>
  <div class="drawer-foot">
    <a class="drawer-donate" href="donate.html">捐款支持</a>
    <div class="drawer-social">
      <a aria-label="facebook" href="https://www.facebook.com/LoveHopeF" target="_blank" rel="noopener"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-9h3l.5-4H13V6.5c0-1.2.3-2 2-2H17V1c-.3 0-1.5-.2-2.8-.2C11.4.8 10 2.7 10 5.9V9H7v4h3v9h3z"/></svg></a>
      <a aria-label="instagram" href="#"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></a>
      <a aria-label="youtube" href="#"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21.6 7.2s-.2-1.4-.8-2c-.7-.8-1.6-.8-2-.9C15.9 4 12 4 12 4s-3.9 0-6.8.3c-.4.1-1.3.1-2 .9-.6.6-.8 2-.8 2S2 8.8 2 10.5v1.5c0 1.7.2 3.3.2 3.3s.2 1.4.8 2c.7.8 1.7.8 2.1.9 1.6.2 6.9.2 6.9.2s3.9 0 6.8-.3c.4-.1 1.3-.1 2-.9.6-.6.8-2 .8-2s.2-1.6.2-3.3v-1.5c0-1.7-.2-3.3-.2-3.3zM10 14V8l5 3-5 3z"/></svg></a>
      <a aria-label="line" href="#"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3C6.5 3 2 6.6 2 11c0 4 3.6 7.4 8.5 8 .3 0 .8.2.9.5.1.2.1.5 0 .8l-.1.6c-.1.2-.3.9.8.5 1.1-.5 5.8-3.4 7.9-5.8C21.5 14 22.5 12.6 22 11c0-4.4-4.5-8-10-8z"/></svg></a>
    </div>
  </div>
</aside>

<!-- ===== BACK TO TOP ===== -->
<a class="cd-top" id="cdTop" href="#" title="回到頂部" aria-label="back to top">↑</a>

<!-- ===== COOKIE ===== -->
<div class="cookie" id="cookieBanner">
  <div class="ctext">
    <strong>Cookie 政策提示</strong>
    本網站使用 Cookie 以提供更好的瀏覽體驗。繼續瀏覽即表示您同意 Cookie 使用。<a href="#">了解更多</a>
  </div>
  <button onclick="document.getElementById('cookieBanner').style.display='none'">同意並關閉</button>
</div>

<script src="app.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>
